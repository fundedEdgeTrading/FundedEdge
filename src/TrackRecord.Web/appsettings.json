{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // La cadena de conexión NO se versiona (sin credenciales en el repo). Se define fuera:
    //  - Local: appsettings.Development.json / User Secrets, o el fallback local por defecto.
    //  - Producción (Render): variable de entorno ConnectionStrings__Default. Admite formato
    //    clave=valor de Npgsql o el URI postgresql://... de Render (se normaliza en AddInfrastructure).
  },
  "Ai": {
    "WeeklyReportEnabled": false,
    "WeeklyReportIntervalDays": 7
  }
}
