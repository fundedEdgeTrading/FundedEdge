@* Tutorial paso a paso, en un modal, de cómo exportar el CSV de operaciones desde Tradovate o
   NinjaTrader 8 y cómo importarlo en FundedEdge desde la propia vista de la cuenta. Se abre
   imperativamente con Show(plataforma) — la pestaña inicial se preselecciona según el feed de
   la cuenta para que el usuario vea directamente su plataforma. *@

@using TrackRecord.Domain.Enums
@inject IStringLocalizer<SharedResources> L

@if (_visible)
{
    <div class="confirm-backdrop" @onclick="Close">
        <div class="confirm-panel tutorial-panel" role="dialog" aria-modal="true" aria-labelledby="tutorial-title" @onclick:stopPropagation="true">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <h3 id="tutorial-title" class="confirm-title mb-0">@L["Cómo importar tus operaciones"]</h3>
                <button type="button" class="btn btn-sm btn-link text-muted p-0" aria-label="@L["Cerrar"]" @onclick="Close">✕</button>
            </div>

            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <button type="button" class="nav-link @(_tab == DataFeedType.Tradovate ? "active" : "")" @onclick="() => _tab = DataFeedType.Tradovate">Tradovate</button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(_tab == DataFeedType.NinjaTrader ? "active" : "")" @onclick="() => _tab = DataFeedType.NinjaTrader">NinjaTrader 8</button>
                </li>
            </ul>

            <div class="tutorial-body">
                @if (_tab == DataFeedType.Tradovate)
                {
                    <h6>@L["1. Exportar el CSV desde Tradovate"]</h6>
                    <ol class="small">
                        <li>@L["Inicia sesión en Tradovate (trader web o aplicación de escritorio) con la cuenta de tu prop firm."]</li>
                        <li>@((MarkupString)L["Abre el menú de la aplicación y entra en <strong>Reports</strong> (Informes)."].Value)</li>
                        <li>@((MarkupString)L["Selecciona la pestaña <strong>Performance</strong>: verás la lista de operaciones cerradas (round-turns)."].Value)</li>
                        <li>@L["Elige arriba la cuenta correcta y el rango de fechas que quieras exportar."]</li>
                        <li>@((MarkupString)L["Pulsa el icono de <strong>descarga</strong> del informe: se guardará un archivo <code>Performance.csv</code>."].Value)</li>
                    </ol>
                    <p class="small text-muted mb-3">
                        @L["Nota: este export no incluye comisiones por operación (Tradovate las liquida a nivel de cuenta). Si quieres contabilizarlas, regístralas como coste de la cuenta (tipo «Other»)."]
                    </p>
                }
                else
                {
                    <h6>@L["1. Exportar el CSV desde NinjaTrader 8"]</h6>
                    <ol class="small">
                        <li>@((MarkupString)L["Abre el <strong>Control Center</strong> de NinjaTrader 8 y ve a <strong>New → Trade Performance</strong>."].Value)</li>
                        <li>@((MarkupString)L["Selecciona tu cuenta en <strong>Account</strong>, el rango de fechas, y pulsa <strong>Generate</strong>."].Value)</li>
                        <li>@((MarkupString)L["Entra en la pestaña <strong>Trades</strong> (la rejilla de operaciones)."].Value)</li>
                        <li>@((MarkupString)L["Recomendado: en <strong>Properties</strong> del informe, usa <strong>Display unit = Currency</strong> y deja visibles las columnas <strong>Profit</strong>, <strong>Commission</strong>, <strong>MAE</strong> y <strong>MFE</strong> — así FundedEdge importa también comisiones y calidad de ejecución."].Value)</li>
                        <li>@((MarkupString)L["Haz clic derecho sobre la rejilla → <strong>Export…</strong> → elige formato <strong>CSV</strong> y guarda el archivo."].Value)</li>
                    </ol>
                }

                <h6>@L["2. Importar el archivo en FundedEdge"]</h6>
                <ol class="small">
                    <li>@((MarkupString)L["En esta misma página de la cuenta, ve a la sección <strong>«Importar operaciones»</strong> y selecciona el archivo CSV descargado."].Value)</li>
                    <li>@L["El formato (Tradovate o NinjaTrader 8) se detecta automáticamente por las cabeceras del archivo — no hay que configurar nada."]</li>
                    <li>@L["Cada fila se convierte en un trade con su símbolo, dirección, precios, fechas, P&L y comisiones; con ellos se calculan el resto de métricas (curva de equity, drawdown, KPIs, cumplimiento de reglas, MAE/MFE…)."]</li>
                    <li>@L["Reimportar el mismo archivo (o uno que solape fechas) no duplica operaciones: las filas ya importadas se omiten."]</li>
                </ol>
            </div>

            <div class="confirm-actions">
                <button type="button" class="btn btn-primary" @onclick="Close">@L["Entendido"]</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _visible;
    private DataFeedType _tab = DataFeedType.Tradovate;

    /// <summary>Abre el tutorial con la pestaña de la plataforma indicada (Manual abre Tradovate).</summary>
    public void Show(DataFeedType platform)
    {
        _tab = platform == DataFeedType.NinjaTrader ? DataFeedType.NinjaTrader : DataFeedType.Tradovate;
        _visible = true;
        StateHasChanged();
    }

    private void Close()
    {
        _visible = false;
        StateHasChanged();
    }
}
