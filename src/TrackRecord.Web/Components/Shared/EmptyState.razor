@* Estado vacío con ilustración minimalista de línea (ejes + tendencia punteada). *@

<div class="empty-state">
    <svg viewBox="0 0 120 72" fill="none" aria-hidden="true">
        <rect x="6" y="6" width="108" height="60" rx="10" stroke="var(--border-strong)" stroke-width="1.5" />
        <path d="M20 52 L98 52" stroke="var(--text-3)" stroke-width="1.5" stroke-linecap="round" opacity="0.55" />
        <path d="M20 52 L38 42 L54 46 L72 30 L88 34 L98 22" stroke="var(--accent)" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="4 5" opacity="0.8" />
        <circle cx="98" cy="22" r="3.5" fill="var(--accent)" opacity="0.9" />
        <circle cx="98" cy="22" r="7.5" stroke="var(--accent)" stroke-width="1.2" opacity="0.35" />
    </svg>
    <div class="empty-title">@Title</div>
    @if (!string.IsNullOrWhiteSpace(Text))
    {
        <div class="empty-text">@Text</div>
    }
    @if (ChildContent is not null)
    {
        <div class="empty-action">@ChildContent</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter] public string? Text { get; set; }
    /// <summary>CTA opcional (botón/enlace) renderizado bajo el texto.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
