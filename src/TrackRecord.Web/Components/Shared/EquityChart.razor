@* Curva de equity: Net P&L acumulado por día de trading. Línea con relleno degradado,
   eje cero visible cuando la curva cruza a negativo y tooltip nativo por punto. *@

@inject IStringLocalizer<SharedResources> L

<svg class="chart-svg" viewBox="0 0 @W @H" preserveAspectRatio="xMidYMid meet" role="img"
     aria-label="@L["Curva de equity: P&L neto acumulado"]">
    <defs>
        <linearGradient id="equity-fill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.28" />
            <stop offset="100%" stop-color="var(--accent)" stop-opacity="0" />
        </linearGradient>
    </defs>

    @foreach (var tick in _ticks)
    {
        <line class="chart-gridline @(tick == 0m ? "chart-zero" : "")"
              x1="@PadL" x2="@(W - PadR)" y1="@F(Y(tick))" y2="@F(Y(tick))" />
        @SvgText("chart-tick", PadL - 7, Y(tick) + 3.5, "end", Compact(tick))
    }

    <polygon class="chart-area" points="@_areaPoints" fill="url(#equity-fill)" />
    <polyline class="chart-line" pathLength="1" points="@_linePoints" />

    @* Marcadores de hover (muestreados si hay muchos puntos) *@
    @foreach (var i in _markerIndexes)
    {
        <circle class="chart-marker" cx="@F(X(i))" cy="@F(Y(Points[i].CumulativeNetPnL))" r="7">
            <title>@Points[i].Date.ToString("d MMM yy"): @Money(Points[i].CumulativeNetPnL) @L["acumulado"]</title>
        </circle>
    }

    <circle class="chart-line-dot" cx="@F(X(Points.Count - 1))" cy="@F(Y(Points[^1].CumulativeNetPnL))" r="3.5" />
    @SvgText($"chart-end-label {(Points[^1].CumulativeNetPnL >= 0 ? "chart-end-good" : "chart-end-bad")}",
             Math.Min(X(Points.Count - 1) + 8, W - 2), EndLabelY(),
             X(Points.Count - 1) + 60 > W - PadR ? "end" : "start", Compact(Points[^1].CumulativeNetPnL))

    @SvgText("chart-tick", PadL, H - 8, "start", Points[0].Date.ToString("d MMM yy"))
    @SvgText("chart-tick", W - PadR, H - 8, "end", Points[^1].Date.ToString("d MMM yy"))
</svg>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<EquityCurvePoint> Points { get; set; } = [];
    [Parameter] public Currency Currency { get; set; } = Currency.Usd;

    private const int W = 720, H = 250, PadL = 48, PadR = 16, PadT = 14, PadB = 26;

    private decimal _min, _max;
    private decimal[] _ticks = [];
    private string _linePoints = "";
    private string _areaPoints = "";
    private int[] _markerIndexes = [];

    protected override void OnParametersSet()
    {
        if (Points.Count == 0)
        {
            return;
        }

        _max = Math.Max(Points.Max(p => p.CumulativeNetPnL), 0m);
        _min = Math.Min(Points.Min(p => p.CumulativeNetPnL), 0m);
        if (_max == _min) { _max = _min + 1; }

        var step = NiceStep((_max - _min) / 4m);
        _max = step * Math.Ceiling(_max / step);
        _min = step * Math.Floor(_min / step);

        var ticks = new List<decimal>();
        for (var t = _min; t <= _max; t += step) { ticks.Add(t); }
        _ticks = [.. ticks];

        _linePoints = string.Join(" ", Enumerable.Range(0, Points.Count)
            .Select(i => $"{F(X(i))},{F(Y(Points[i].CumulativeNetPnL))}"));
        _areaPoints = $"{F(X(0))},{F(Y(Math.Max(_min, 0m)))} {_linePoints} {F(X(Points.Count - 1))},{F(Y(Math.Max(_min, 0m)))}";

        // Como mucho ~48 zonas de hover para no saturar el DOM
        var stride = Math.Max(1, (int)Math.Ceiling(Points.Count / 48.0));
        _markerIndexes = [.. Enumerable.Range(0, Points.Count).Where(i => i % stride == 0 || i == Points.Count - 1)];
    }

    private double X(int i) => Points.Count == 1
        ? (PadL + W - PadR) / 2.0
        : PadL + (double)i / (Points.Count - 1) * (W - PadL - PadR);

    private double Y(decimal value) =>
        PadT + (double)((_max - value) / (_max - _min)) * (H - PadT - PadB);

    private double EndLabelY()
    {
        var y = Y(Points[^1].CumulativeNetPnL);
        return Math.Clamp(y + 3.5, PadT + 9, H - PadB - 3);
    }

    private static decimal NiceStep(decimal rough)
    {
        if (rough <= 0) { return 1; }
        var magnitude = (decimal)Math.Pow(10, Math.Floor(Math.Log10((double)rough)));
        var residual = rough / magnitude;
        return residual switch { <= 1 => magnitude, <= 2 => 2 * magnitude, <= 5 => 5 * magnitude, _ => 10 * magnitude };
    }

    private string Compact(decimal v)
    {
        var abs = Math.Abs(v);
        var symbol = TrackRecord.Domain.Common.CurrencyFormatter.Symbol(Currency);
        return abs >= 1000 ? $"{symbol}{v / 1000m:0.#}k" : $"{symbol}{v:0}";
    }

    private string Money(decimal v) => TrackRecord.Domain.Common.CurrencyFormatter.Format(v, Currency, decimals: 0);

    private static string F(double v) => v.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    // Razor reserva la etiqueta <text>, así que los textos SVG se emiten como marcado.
    private static MarkupString SvgText(string cls, double x, double y, string anchor, string content) =>
        new($"<text class=\"{cls}\" x=\"{F(x)}\" y=\"{F(y)}\" text-anchor=\"{anchor}\">{System.Net.WebUtility.HtmlEncode(content)}</text>");
}
