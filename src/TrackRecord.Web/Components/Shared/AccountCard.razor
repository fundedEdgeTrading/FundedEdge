@* Tarjeta de cuenta para listados: progreso a profit target y
   costes/payouts en el pie. Toda la tarjeta es clicable. *@
@inject CurrencyState Currency
@inject IStringLocalizer<SharedResources> L

<div class="account-card" tabindex="0" role="link"
     @onclick="() => OnOpen.InvokeAsync(Account.Id)"
     @onkeydown="OnKeyDown">
    <div class="ac-head">
        <div class="firm-mark">@FirmInitials</div>
        <div class="ac-title">
            <b>@Account.DisplayName</b>
            <span>@Account.PropFirmName · @Currency.Format(Account.AccountSize, 0)</span>
        </div>
        <span class="stage @StageClass">@Account.Stage</span>
    </div>
    @if (Account.ProfitTarget > 0 || Compliance is not null)
    {
        <div class="meters">
            @if (Account.ProfitTarget > 0)
            {
                <div>
                    <div class="meter-cap">
                        <span>@L["Objetivo"]</span>
                        <span class="mono">@TargetPct%</span>
                    </div>
                    <div class="track"><div class="fill fill-target" style="width:@(TargetPct)%"></div></div>
                </div>
            }
            @if (Compliance is not null)
            {
                <div>
                    <div class="meter-cap">
                        <span>@L["Drawdown consumido"]</span>
                        <span class="mono">@DrawdownPct%</span>
                    </div>
                    <div class="track"><div class="fill @DrawdownFillClass" style="width:@(DrawdownPct)%"></div></div>
                </div>
            }
        </div>
    }
    <div class="ac-foot">
        <span class="kv">@L["Costes"] <b>@Currency.Format(Account.TotalCosts, 0)</b> · Payouts <b>@Currency.Format(Account.TotalPayoutsReceived, 0)</b></span>
        <span class="go">@L["Ver detalle"] →</span>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public TradingAccountListItemDto Account { get; set; } = default!;
    [Parameter] public AccountComplianceStatusDto? Compliance { get; set; }
    [Parameter] public EventCallback<Guid> OnOpen { get; set; }

    // Objetivo efectivo: incluye la elevación por la regla de consistencia si aplica.
    private decimal EffectiveTarget => Account.EffectiveProfitTarget > 0 ? Account.EffectiveProfitTarget : Account.ProfitTarget;

    private int TargetPct => EffectiveTarget <= 0 ? 0
        : (int)Math.Clamp(Math.Round(Account.NetPnL / EffectiveTarget * 100), 0, 100);

    // Fracción consumida del colchón de drawdown: mismo cálculo que el semáforo de reglas
    // (RuleComplianceService), aquí solo para el color/ancho del medidor de la tarjeta.
    private double DrawdownFraction => Compliance is null || Compliance.DrawdownLimit <= 0 ? 0
        : Math.Clamp(1 - (double)(Compliance.DrawdownRemainingBuffer / Compliance.DrawdownLimit), 0, 1);

    private int DrawdownPct => (int)Math.Round(DrawdownFraction * 100);

    private string DrawdownFillClass => DrawdownFraction switch
    {
        >= 0.75 => "fill-hot",
        >= 0.5 => "fill-warn",
        _ => "fill-ok",
    };

    private string FirmInitials
    {
        get
        {
            var words = Account.PropFirmName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            return words.Length switch
            {
                0 => "?",
                1 => words[0][..Math.Min(2, words[0].Length)].ToUpperInvariant(),
                _ => $"{char.ToUpperInvariant(words[0][0])}{char.ToUpperInvariant(words[1][0])}",
            };
        }
    }

    private string StageClass => Account.Stage switch
    {
        AccountStage.Funded => "stage-funded",
        AccountStage.Failed => "stage-failed",
        AccountStage.Expired => "stage-warn",
        AccountStage.Withdrawn => "stage-muted",
        _ => "stage-eval",
    };

    private Task OnKeyDown(KeyboardEventArgs e)
        => e.Key is "Enter" or " " ? OnOpen.InvokeAsync(Account.Id) : Task.CompletedTask;
}
