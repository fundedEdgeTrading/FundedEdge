@using Microsoft.AspNetCore.Components.Authorization
@using TrackRecord.Infrastructure.Identity
@inject CurrencyState CurrencyState
@inject IStringLocalizer<SharedResources> L

<div class="nav-header">
    <a class="brand" href="" aria-label="@($"{Brand.Name} — inicio")">
        <span class="brand-mark">
            <span class="brand-mark-glass"></span>
            <span class="brand-mark-sheen"></span>
            <svg class="brand-logo" viewBox="0 0 28 28" aria-hidden="true">
                <defs>
                    <linearGradient id="logoInk" x1="0" y1="1" x2="0" y2="0">
                        <stop offset="0%" stop-color="#04241b" />
                        <stop offset="100%" stop-color="#0a3d2d" />
                    </linearGradient>
                </defs>
                <rect class="logo-bar" x="4.5" y="15" width="3.6" height="8.5" rx="1.1" fill="url(#logoInk)" opacity="0.88" />
                <rect class="logo-bar" x="12.2" y="10.2" width="3.6" height="13.3" rx="1.1" fill="url(#logoInk)" opacity="0.94" />
                <rect class="logo-bar" x="19.9" y="5.6" width="3.6" height="17.9" rx="1.1" fill="url(#logoInk)" />
                <path class="logo-line" d="M4 12.5 L11 7.6 L16.3 10.9 L24.3 3.4" pathLength="1" fill="none" stroke="#06281f" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" />
                <path class="logo-tip" d="M18.6 3.1 L24.3 3.4 L24.6 9.1" pathLength="1" fill="none" stroke="#06281f" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </span>
        <span class="brand-text">
            <span class="brand-name">Funded<span class="brand-edge">Edge</span></span>
            <span class="brand-sub"><span class="brand-sub-tick"></span>Trading Intelligence</span>
        </span>
    </a>
</div>

<input type="checkbox" title="@L["Menú de navegación"]" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav-menu">
        <span class="nav-section">@L["General"]</span>

        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="7" height="9" rx="1.5" /><rect x="14" y="3" width="7" height="5" rx="1.5" />
                <rect x="14" y="12" width="7" height="9" rx="1.5" /><rect x="3" y="16" width="7" height="5" rx="1.5" />
            </svg>
            <span>Dashboard</span>
        </NavLink>

        <NavLink class="nav-link" href="accounts">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4" /><path d="M3 5v14a2 2 0 0 0 2 2h16v-5" />
                <path d="M18 12a2 2 0 0 0 0 4h4v-4Z" />
            </svg>
            <span>@L["Cuentas"]</span>
        </NavLink>

        <NavLink class="nav-link" href="firms">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18" /><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" />
                <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" /><path d="M10 6h4" /><path d="M10 10h4" /><path d="M10 14h4" /><path d="M10 18h4" />
            </svg>
            <span>@L["Firmas"]</span>
        </NavLink>

        <span class="nav-section">@L["Análisis"]</span>

        <NavLink class="nav-link" href="risk">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
            </svg>
            <span>@L["Riesgo"]</span>
        </NavLink>

        <NavLink class="nav-link" href="firm-fit">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="9" /><circle cx="12" cy="12" r="5" /><circle cx="12" cy="12" r="1" />
            </svg>
            <span>Firm Fit</span>
        </NavLink>

        <NavLink class="nav-link" href="ai">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z" />
                <path d="M5 3v4" /><path d="M3 5h4" />
            </svg>
            <span>@L["Análisis IA"]</span>
        </NavLink>

        <NavLink class="nav-link" href="psychology">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 21c-3.5-2-6-5.2-6-9a6 6 0 0 1 12 0c0 3.8-2.5 7-6 9Z" /><circle cx="12" cy="11" r="2.3" />
            </svg>
            <span>@L["Psicología"]</span>
        </NavLink>

        <NavLink class="nav-link" href="setups">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m9 18 6-6-6-6" /><path d="M4 6h1" /><path d="M4 12h4" /><path d="M4 18h9" />
            </svg>
            <span>@L["Setups"]</span>
        </NavLink>

        <NavLink class="nav-link" href="peers">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 9H4.5a2.5 2.5 0 0 0 0 5H6" /><path d="M18 9h1.5a2.5 2.5 0 0 1 0 5H18" /><path d="M8 22h8" /><path d="M7 4h10" /><path d="M12 22V4" /><path d="M6 4v6a6 6 0 0 0 12 0V4" />
            </svg>
            <span>@L["Perfiles Elite"]</span>
        </NavLink>

        <span class="nav-section">@L["Sistema"]</span>

        <NavLink class="nav-link" href="plan">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2" /><path d="M3 10h18" /><path d="M7 15h4" />
            </svg>
            <span>@L["Tu plan"]</span>
        </NavLink>

        <NavLink class="nav-link" href="export">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3v12" /><path d="m7 10 5 5 5-5" /><path d="M5 21h14" />
            </svg>
            <span>@L["Exportar"]</span>
        </NavLink>

        <NavLink class="nav-link" href="settings">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="21" x2="14" y1="4" y2="4" /><line x1="10" x2="3" y1="4" y2="4" />
                <line x1="21" x2="12" y1="12" y2="12" /><line x1="8" x2="3" y1="12" y2="12" />
                <line x1="21" x2="16" y1="20" y2="20" /><line x1="12" x2="3" y1="20" y2="20" />
                <line x1="14" x2="14" y1="2" y2="6" /><line x1="8" x2="8" y1="10" y2="14" /><line x1="16" x2="16" y1="18" y2="22" />
            </svg>
            <span>@L["Ajustes"]</span>
        </NavLink>

        <AuthorizeView Roles="Administrator,Support">
            <span class="nav-section">@L["Administración"]</span>
            <NavLink class="nav-link" href="admin" Match="NavLinkMatch.All">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" />
                </svg>
                <span>@L["Usuarios"]</span>
            </NavLink>
            <NavLink class="nav-link" href="admin/kpis">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 3v18h18" /><path d="M7 15l4-4 3 3 5-6" />
                </svg>
                <span>@L["KPIs por usuario"]</span>
            </NavLink>
        </AuthorizeView>
        <AuthorizeView Roles="Administrator">
            <NavLink class="nav-link" href="admin/prop-firms">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18" /><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" />
                    <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" /><path d="M10 6h4" /><path d="M10 10h4" /><path d="M10 14h4" /><path d="M10 18h4" />
                </svg>
                <span>@L["Reglas de prop firms"]</span>
            </NavLink>
        </AuthorizeView>
    </nav>

    <div class="nav-footer">
        <span class="nav-section">@L["Divisa"]</span>
        <div class="currency-toggle" role="group" aria-label="@L["Divisa de visualización"]">
            <button type="button" class="currency-option @(CurrencyState.Current == Currency.Usd ? "active" : "")"
                    @onclick='() => SetCurrencyAsync(Currency.Usd)'>
                $ USD
            </button>
            <button type="button" class="currency-option @(CurrencyState.Current == Currency.Eur ? "active" : "")"
                    @onclick='() => SetCurrencyAsync(Currency.Eur)'>
                € EUR
            </button>
        </div>

        <span class="nav-section">@L["Idioma"]</span>
        <div class="nav-lang"><CultureSelector /></div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-user">
                    @if (AvatarUrl(context.User) is { } avatarUrl)
                    {
                        <img class="nav-user-avatar" src="@avatarUrl" alt="" />
                    }
                    else
                    {
                        <span class="nav-user-avatar">@UserInitial(context.User)</span>
                    }
                    <a class="nav-user-name" href="/settings/profile">@DisplayName(context.User)</a>
                </div>
                <form action="Account/Logout" method="post">
                    <AntiforgeryToken />
                    <input type="hidden" name="returnUrl" value="" />
                    <button type="submit" class="btn btn-outline-secondary w-100 btn-sm">@L["Cerrar sesión"]</button>
                </form>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync() => await CurrencyState.EnsureLoadedAsync();

    private async Task SetCurrencyAsync(Currency currency)
    {
        if (CurrencyState.Current == currency) return;
        await CurrencyState.SetAsync(currency);
    }

    private static string DisplayName(System.Security.Claims.ClaimsPrincipal user)
    {
        var name = user.FindFirst(c => c.Type == "DisplayName")?.Value;
        return !string.IsNullOrWhiteSpace(name) ? name : user.Identity?.Name ?? "Usuario";
    }

    private static string? AvatarUrl(System.Security.Claims.ClaimsPrincipal user)
    {
        var url = user.FindFirst(c => c.Type == "AvatarUrl")?.Value;
        return string.IsNullOrWhiteSpace(url) ? null : url;
    }

    private static string UserInitial(System.Security.Claims.ClaimsPrincipal user) =>
        DisplayName(user).Trim() is { Length: > 0 } name ? name[..1].ToUpperInvariant() : "?";
}
