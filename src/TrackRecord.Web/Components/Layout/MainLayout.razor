@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject IStringLocalizer<SharedResources> L

<div class="page">
    @* Isla interactiva: <Routes> se renderiza estático (ver App.razor), así que sin esto los
       @onclick del selector de divisa no responden — no hay circuito escuchando en el layout. *@
    <div class="sidebar">
        <NavMenu @rendermode="InteractiveServer" />
    </div>

    <main>
        @* Aviso de sesión impersonada (claim añadido por POST /admin/impersonate). *@
        <AuthorizeView>
            @if (context.User.HasClaim(c => c.Type == "ImpersonatedBy"))
            {
                <div class="alert alert-warning rounded-0 mb-0 py-2 px-4 d-flex justify-content-between align-items-center">
                    <span>@L["Sesión impersonada por un administrador."]</span>
                    <form action="Account/Logout" method="post" class="mb-0">
                        <AntiforgeryToken />
                        <input type="hidden" name="returnUrl" value="" />
                        <button type="submit" class="btn btn-sm btn-outline-dark">@L["Cerrar sesión"]</button>
                    </form>
                </div>
            }
        </AuthorizeView>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @L["Se ha producido un error inesperado."]
    <a href="." class="reload">@L["Recargar"]</a>
    <span class="dismiss">🗙</span>
</div>
