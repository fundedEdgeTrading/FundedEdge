@page "/admin/kpis"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Administrator,Support")]
@rendermode InteractiveServer
@implements IDisposable
@inject IAdminUserService AdminService
@inject IStringLocalizer<SharedResources> L
@inject TrackRecord.Web.State.CurrencyState Currency

<PageTitle>@L["KPIs por usuario"] — @Brand.Name</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@L["KPIs por usuario"]</h1>
    <a class="btn btn-outline-secondary" href="admin">@L["Volver a usuarios"]</a>
</div>

@if (_kpis is null)
{
    <p><em>@L["Cargando..."]</em></p>
}
else
{
    <p class="text-muted">@L["Ordenados de mayor a menor ROI de negocio (payouts frente a costes)."]</p>
    <div class="row g-3">
        @foreach (var (user, index) in _kpis.Select((k, i) => (k, i)))
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h5 class="card-title mb-0">#@(index + 1) @(string.IsNullOrWhiteSpace(user.DisplayName) ? user.Email : user.DisplayName)</h5>
                                <small class="text-muted">@user.Email · @user.PlanTier</small>
                            </div>
                            <span class="badge fs-6 @RoiBadge(user.BusinessRoi)">
                                @(user.BusinessRoi is double roi ? roi.ToString("P1") : "—") ROI
                            </span>
                        </div>
                        <div class="row text-center mt-3">
                            <div class="col-4">
                                <div class="fw-bold">@user.ActiveAccounts</div>
                                <small class="text-muted">@L["Cuentas activas"]</small>
                            </div>
                            <div class="col-4">
                                <div class="fw-bold">@user.FundedAccounts</div>
                                <small class="text-muted">@L["Fondeadas"]</small>
                            </div>
                            <div class="col-4">
                                <div class="fw-bold">@user.TotalTrades</div>
                                <small class="text-muted">@L["Trades"]</small>
                            </div>
                        </div>
                        <div class="row text-center mt-3">
                            <div class="col-4">
                                <div class="fw-bold">@Currency.Format(user.TotalCosts, 0)</div>
                                <small class="text-muted">@L["Costes"]</small>
                            </div>
                            <div class="col-4">
                                <div class="fw-bold">@Currency.Format(user.TotalPayouts, 0)</div>
                                <small class="text-muted">@L["Payouts"]</small>
                            </div>
                            <div class="col-4">
                                <div class="fw-bold @(user.NetCashflow < 0 ? "text-danger" : "text-success")">@Currency.Format(user.NetCashflow, 0)</div>
                                <small class="text-muted">@L["Neto"]</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private IReadOnlyList<AdminUserKpis>? _kpis;

    protected override async Task OnInitializedAsync()
    {
        Currency.Changed += OnCurrencyChanged;
        _kpis = await AdminService.GetUserKpisAsync();
    }

    private void OnCurrencyChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Currency.Changed -= OnCurrencyChanged;

    private static string RoiBadge(double? roi) => roi switch
    {
        null => "text-bg-secondary",
        < 0 => "text-bg-danger",
        _ => "text-bg-success",
    };
}
