@page "/admin/rule-monitor"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Administrator")]
@rendermode InteractiveServer
@inject IPropFirmService PropFirmService
@inject IRuleSourceService SourceService
@inject IRuleSourceChecker Checker
@inject IProgramChangeProposalService ProposalService
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Monitor de reglas"] — @Brand.Name</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@L["Monitor de reglas"]</h1>
    <a class="btn btn-outline-secondary" href="admin/prop-firms">@L["Volver a reglas de firmas"]</a>
</div>
<p class="text-muted">
    @L["Fuentes oficiales (pricing, FAQ, reglas) que se comprueban a diario. Si el contenido de una página cambia, se marca aquí y se avisa por email al administrador."]
</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
@if (_info is not null)
{
    <div class="alert alert-info">@_info</div>
}

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">@(_editingId is null ? L["Añadir fuente"] : L["Editar fuente"])</h5>
        <EditForm Model="_form" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger small mb-2" />
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">@L["Firma"]</label>
                    <InputSelect class="form-select" @bind-Value="_form.PropFirmId">
                        <option value="">@L["Selecciona una firma"]</option>
                        @if (_firms is not null)
                        {
                            @foreach (var f in _firms)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        }
                    </InputSelect>
                </div>
                <div class="col-md-5">
                    <label class="form-label">URL</label>
                    <InputText class="form-control" @bind-Value="_form.Url" placeholder="https://..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label">@L["Tipo"]</label>
                    <InputSelect class="form-select" @bind-Value="_form.Kind">
                        @foreach (var v in Enum.GetValues<RuleSourceKind>())
                        {
                            <option value="@v">@v</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-1">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="_form.IsEnabled" id="src-enabled" />
                        <label class="form-check-label" for="src-enabled">@L["Activa"]</label>
                    </div>
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary">@(_editingId is null ? L["Añadir"] : L["Guardar"])</button>
                </div>
            </div>
            @if (_editingId is not null)
            {
                <button type="button" class="btn btn-link btn-sm mt-1" @onclick="CancelEdit">@L["Cancelar edición"]</button>
            }
        </EditForm>
    </div>
</div>

@if (_sources is null)
{
    <p><em>@L["Cargando…"]</em></p>
}
else if (_sources.Count == 0)
{
    <p class="text-muted">@L["Todavía no hay fuentes monitorizadas. Añade la página de pricing o FAQ de cada firma."]</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>@L["Firma"]</th>
                    <th>URL</th>
                    <th>@L["Tipo"]</th>
                    <th>@L["Última comprobación"]</th>
                    <th>@L["Último cambio"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _sources)
                {
                    <tr class="@(s.IsEnabled ? null : "text-muted")">
                        <td>
                            @s.PropFirmName
                            @if (!s.IsEnabled)
                            {
                                <span class="badge bg-secondary ms-1">@L["inactiva"]</span>
                            }
                        </td>
                        <td class="text-truncate" style="max-width: 320px;"><a href="@s.Url" target="_blank" rel="noopener">@s.Url</a></td>
                        <td>@s.Kind</td>
                        <td>
                            @(s.LastCheckedAt?.LocalDateTime.ToString("g") ?? "—")
                            @if (s.LastError is not null)
                            {
                                <span class="badge bg-danger ms-1" title="@s.LastError">@L["Error"]</span>
                            }
                        </td>
                        <td>@(s.LastChangedAt?.LocalDateTime.ToString("g") ?? "—")</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => CheckNowAsync(s.Id, false)" disabled="@(_checkingId is not null)">
                                @(_checkingId == s.Id ? L["Comprobando…"] : L["Comprobar ahora"])
                            </button>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => CheckNowAsync(s.Id, true)" disabled="@(_checkingId is not null)"
                                    title="@L["Ejecuta la extracción con IA aunque la página no haya cambiado"]">
                                🤖 @L["Extraer ahora"]
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => Edit(s)">@L["Editar"]</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(s.Id)">@L["Eliminar"]</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted small mt-2">
        @L["La primera comprobación de una fuente solo establece la línea base; los avisos empiezan a partir de la segunda. El barrido automático requiere RuleMonitor:Enabled=true en la configuración."]
    </p>
}

@* ── Propuestas pendientes (extracción LLM) ─────────────────────────────────────────────────── *@

<hr class="my-4" />
<h2 class="h4">@L["Propuestas de cambio pendientes"]</h2>
<p class="text-muted">
    @L["Cambios extraídos automáticamente de las páginas oficiales. Aprobar aplica el versionado habitual del catálogo (la versión anterior queda inactiva); nada se escribe sin revisión."]
</p>

@if (_proposalError is not null)
{
    <div class="alert alert-danger">@_proposalError</div>
}

@if (_proposals is null)
{
    <p><em>@L["Cargando…"]</em></p>
}
else if (_proposals.Count == 0)
{
    <p class="text-muted">@L["No hay propuestas pendientes de revisión."]</p>
}
else
{
    @foreach (var prop in _proposals)
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="card-title mb-1">
                            @prop.PropFirmName — @prop.ProgramName
                            @if (prop.ExistingProgramId is null)
                            {
                                <span class="badge bg-info ms-1">@L["Programa nuevo"]</span>
                            }
                            <span class="badge @(prop.Confidence >= 0.8m ? "bg-success" : "bg-warning text-dark") ms-1">
                                @L["Confianza"] @prop.Confidence.ToString("P0")
                            </span>
                        </h6>
                        <div class="text-muted small">
                            @prop.CreatedAt.LocalDateTime.ToString("g")
                            @if (prop.SourceUrl is not null)
                            {
                                <span> · <a href="@prop.SourceUrl" target="_blank" rel="noopener">@L["fuente"]</a></span>
                            }
                        </div>
                    </div>
                    <div class="d-flex gap-1">
                        @if (_confirmApproveId == prop.Id)
                        {
                            <button class="btn btn-sm btn-success" @onclick="() => ApproveAsync(prop.Id)" disabled="@_reviewing">@L["Confirmar y aplicar"]</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _confirmApproveId = null">@L["Cancelar"]</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-success" @onclick="() => _confirmApproveId = prop.Id" disabled="@_reviewing">@L["Aprobar"]</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RejectAsync(prop.Id)" disabled="@_reviewing">@L["Rechazar"]</button>
                        }
                    </div>
                </div>
                <div class="table-responsive mt-2">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>@L["Campo"]</th>
                                <th class="text-end">@L["Actual"]</th>
                                <th class="text-end">@L["Propuesto"]</th>
                                <th>@L["Cita de la página"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in prop.Diffs)
                            {
                                <tr>
                                    <td class="font-monospace">@d.Field</td>
                                    <td class="text-end">@(d.CurrentValue ?? "—")</td>
                                    <td class="text-end fw-semibold">@d.ProposedValue</td>
                                    <td class="text-muted small">
                                        @if (d.Quote is not null)
                                        {
                                            <em>"@d.Quote"</em>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark" title="@L["El modelo no aportó cita para este campo: verifícalo en la página antes de aprobar."]">@L["sin cita"]</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<PropFirmDto>? _firms;
    private List<RuleSourceDto>? _sources;
    private Guid? _editingId;
    private Guid? _checkingId;
    private SourceFormModel _form = new();
    private string? _error;
    private string? _info;

    // ── Propuestas ───────────────────────────────────────────────────────────────────────────
    private List<ProposedProgramChangeDto>? _proposals;
    private Guid? _confirmApproveId;
    private bool _reviewing;
    private string? _proposalError;

    protected override async Task OnInitializedAsync()
    {
        _firms = (await PropFirmService.GetAllAsync()).ToList();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _sources = (await SourceService.GetAllAsync()).ToList();
        _proposals = (await ProposalService.GetPendingAsync()).ToList();
    }

    private void Edit(RuleSourceDto s)
    {
        _editingId = s.Id;
        _form = new SourceFormModel { PropFirmId = s.PropFirmId, Url = s.Url, Kind = s.Kind, IsEnabled = s.IsEnabled };
    }

    private void CancelEdit()
    {
        _editingId = null;
        _form = new SourceFormModel();
    }

    private async Task SaveAsync()
    {
        _error = null;
        _info = null;
        if (_form.PropFirmId is null)
        {
            _error = L["Selecciona una firma."];
            return;
        }

        var request = new UpsertRuleSourceRequest(_form.PropFirmId.Value, _form.Url, _form.Kind, _form.IsEnabled);
        try
        {
            if (_editingId is null)
                await SourceService.CreateAsync(request);
            else
                await SourceService.UpdateAsync(_editingId.Value, request);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            return;
        }
        CancelEdit();
        await LoadAsync();
    }

    private async Task DeleteAsync(Guid id)
    {
        _error = null;
        _info = null;
        try
        {
            await SourceService.DeleteAsync(id);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task CheckNowAsync(Guid id, bool forceExtraction)
    {
        _error = null;
        _info = null;
        _checkingId = id;
        try
        {
            var result = await Checker.CheckAsync(id, forceExtraction);
            _info = result switch
            {
                { Error: not null } => L["La comprobación falló: "] + result.Error,
                { Changed: true } => L["El contenido de la página cambió desde la última comprobación."],
                _ => L["Sin cambios respecto a la última comprobación."],
            };
            if (result.ProposalsCreated > 0)
            {
                _info += " " + L["Propuestas pendientes de revisión: "] + result.ProposalsCreated;
            }
            else if (result.ExtractionError is not null)
            {
                _error = L["La extracción falló: "] + result.ExtractionError;
            }
            else if (forceExtraction && result.Error is null)
            {
                _info += " " + L["La extracción no encontró diferencias con el catálogo."];
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _checkingId = null;
        }
        await LoadAsync();
    }

    // ── Revisión de propuestas ───────────────────────────────────────────────────────────────

    private async Task ApproveAsync(Guid id)
    {
        _proposalError = null;
        _reviewing = true;
        try
        {
            await ProposalService.ApproveAsync(id);
        }
        catch (Exception ex)
        {
            _proposalError = ex.Message;
        }
        finally
        {
            _reviewing = false;
            _confirmApproveId = null;
        }
        await LoadAsync();
    }

    private async Task RejectAsync(Guid id)
    {
        _proposalError = null;
        _reviewing = true;
        try
        {
            await ProposalService.RejectAsync(id);
        }
        catch (Exception ex)
        {
            _proposalError = ex.Message;
        }
        finally
        {
            _reviewing = false;
        }
        await LoadAsync();
    }

    private class SourceFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public Guid? PropFirmId { get; set; }
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.Url]
        public string Url { get; set; } = "";
        public RuleSourceKind Kind { get; set; } = RuleSourceKind.Pricing;
        public bool IsEnabled { get; set; } = true;
    }
}
