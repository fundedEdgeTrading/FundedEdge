@page "/settings"
@rendermode InteractiveServer
@using TrackRecord.Infrastructure.Ai
@inject ITradingAccountService AccountService
@inject AiOptions AiOptions
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Ajustes"] — @Brand.Name</PageTitle>

<h1>@L["Ajustes"]</h1>
<p class="text-muted">
    @L["Los trades se importan desde el CSV que exportan Tradovate o NinjaTrader 8 — sin credenciales ni API keys. La importación (y su tutorial paso a paso) está en la página de detalle de cada cuenta."]
</p>

<div class="card mb-4 mt-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <h5 class="card-title">@L["Análisis con IA (Claude)"]</h5>
            @if (AiOptions.IsApiKeyConfigured)
            {
                <span class="stage stage-funded">@L["Configurado"]</span>
            }
            else
            {
                <span class="stage stage-muted">@L["Sin configurar"]</span>
            }
        </div>
        <p class="small text-muted mb-0">
            @((MarkupString)L["La clave de Anthropic solo se lee de la variable de entorno <code>ANTHROPIC_API_KEY</code> o de <code>Ai:ApiKey</code> en User Secrets — nunca se guarda desde esta pantalla ni en base de datos, para evitar exponerla. Ver <code>README.md</code>."].Value)
        </p>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@L["Cuentas y su plataforma"]</h5>
        <p class="small text-muted">
            @L["La plataforma de cada cuenta se edita desde su propia página de detalle, donde también está la importación de CSV."]
        </p>
        @if (_accounts is null)
        {
            <div aria-label="@L["Cargando…"]">
                <div class="skeleton skeleton-label mb-2" style="width:70%"></div>
                <div class="skeleton skeleton-label mb-2" style="width:85%"></div>
                <div class="skeleton skeleton-label" style="width:60%"></div>
            </div>
        }
        else
        {
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@L["Cuenta"]</th>
                        <th>@L["Plataforma"]</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in _accounts)
                    {
                        <tr>
                            <td>@a.DisplayName</td>
                            <td>@a.Feed</td>
                            <td><a href="@($"/accounts/{a.Id}")">@L["Editar"] →</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private List<TradingAccountListItemDto>? _accounts;

    protected override async Task OnInitializedAsync() =>
        _accounts = (await AccountService.GetAllAsync()).ToList();
}
