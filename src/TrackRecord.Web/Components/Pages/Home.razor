@page "/"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@implements IDisposable
@using System.Globalization
@inject IKpiService KpiService
@inject IRiskAnalysisService RiskAnalysisService
@inject IPlanService PlanService
@inject IPsychologyService PsychologyService
@inject IRuleComplianceService RuleComplianceService
@inject CurrencyState Currency
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

<PageTitle>Dashboard — @Brand.Name</PageTitle>

<h1>Dashboard</h1>
<p class="text-muted">@L["Visión general del negocio de fondeo y de tu operativa."]</p>

@if (_pendingEmotionCount > 0)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center">
        <span>@L["Tienes {0} trade(s) sin diario emocional — completarlo lleva menos de un minuto.", _pendingEmotionCount]</span>
        <a class="btn btn-sm btn-outline-primary" href="emotion-survey">@L["Registrar ahora"]</a>
    </div>
}

@if (_drawdownAlerts is { Count: > 0 })
{
    <div class="alert alert-danger">
        <strong><span class="alert-dot" aria-hidden="true"></span>@L["Aviso de drawdown:"]</strong>
        @foreach (var alert in _drawdownAlerts)
        {
            <div>@L["{0} — {1} del colchón de drawdown consumido (quedan {2}).", alert.AccountDisplayName, alert.ConsumedFraction.ToString("P0"), Currency.Format(alert.RemainingBuffer)]</div>
        }
    </div>
}

@if (_business is not null && _trading is not null)
{
    <div class="hero-grid">
        <KpiCard Variant="hero" Title="@L["Cashflow neto"]"
                 Value="@Currency.Format(_business.NetCashflow)"
                 Emphasis="@(_business.NetCashflow >= 0 ? "text-success" : "text-danger")"
                 Sub="@($"{Currency.Format(_business.TotalPayoutsReceived, 0)} payouts − {Currency.Format(_business.TotalCosts, 0)} {L["Costes"].Value.ToLowerInvariant()}")">
            <Spark>
                <svg class="spark" viewBox="0 0 232 40" preserveAspectRatio="none" style="color:var(--good)">
                    <path class="spark-area" d="M2,34 L40,32 L78,27 L116,22 L154,17 L192,13 L230,8 L230,40 L2,40 Z" fill="var(--good-soft)" />
                    <path class="spark-line" d="M2,34 L40,32 L78,27 L116,22 L154,17 L192,13 L230,8" stroke="var(--good)" />
                </svg>
            </Spark>
        </KpiCard>

        <KpiCard Variant="hero" Title="@L["ROI del negocio"]"
                 Value="@FormatPercent(_business.BusinessRoi)" Emphasis="@RoiEmphasis">
            <Spark>
                <div class="hero-meter">
                    <span style="width:@(Math.Clamp((_business.BusinessRoi ?? 0) * 100, 0, 100).ToString("0", CultureInfo.InvariantCulture))%"></span>
                </div>
            </Spark>
        </KpiCard>

    </div>
}

@if (_compliance is { Count: > 0 })
{
    <h2>@L["Semáforo de reglas"]</h2>
    <div class="rule-grid">
        @foreach (var c in _compliance)
        {
            <div class="rule-card">
                <div class="rule-rail @RailClass(c)"></div>
                <div class="rule-body">
                    <div class="rule-head">
                        <b>@c.AccountDisplayName</b>
                        <span class="stage @OverallStageClass(c)">@OverallStageText(c)</span>
                    </div>
                    <div class="rule-row">
                        <span>@L["Pérdida diaria"]</span>
                        <span class="rule-val">
                            @Dot(c.DailyLossLevel)
                            @(c.DailyLossLimit is null ? L["N/A"].Value : L["quedan {0}", Currency.Format(c.DailyLossRemaining ?? 0, 0)].Value)
                        </span>
                    </div>
                    <div class="rule-row">
                        <span>@L["Drawdown"]</span>
                        <span class="rule-val">@Dot(c.DrawdownLevel) @L["colchón {0}", Currency.Format(c.DrawdownRemainingBuffer, 0)]</span>
                    </div>
                    <div class="rule-row">
                        <span>@L["Consistencia"]</span>
                        <span class="rule-val">
                            @if (c.ConsistencyLevel is null)
                            {
                                @L["N/A"]
                            }
                            else
                            {
                                @Dot(c.ConsistencyLevel.Value)
                                @($"{c.ConsistencyTopDayFraction:P0} / {c.ConsistencyMaxDayFraction:P0}")
                            }
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (_business is null || _trading is null)
{
    <h2>@L["Negocio de fondeo"]</h2>
    <div class="kpi-grid">
        @for (var i = 0; i < 8; i++)
        {
            <div class="stat-tile">
                <div class="skeleton skeleton-label"></div>
                <div class="skeleton skeleton-value"></div>
            </div>
        }
    </div>
}
else
{
    <h2>@L["Evolución"]</h2>
    <div class="chart-grid">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@L["Cashflow mensual"]</h5>
                <p class="chart-caption">@L["Lo que entra (payouts) contra lo que se gasta en evaluaciones y cuotas, mes a mes, con el neto acumulado del negocio."]</p>
                @if (_cashflow is { Count: > 0 })
                {
                    <CashflowChart Points="_cashflow" Currency="Currency.Current" />
                }
                else
                {
                    <EmptyState Title="@L["Sin movimientos todavía"]"
                                Text="@L["Registra costes y payouts en tus cuentas para ver el cashflow mensual."]" />
                }
            </div>
        </div>
    </div>

    <h2>@L["Negocio de fondeo"]</h2>
    <div class="kpi-grid">
        <KpiCard Title="Pass rate" Value="@FormatPercent(_business.PassRate)" />
        <KpiCard Title="@L["Cuentas compradas"]" Value="@_business.AccountsPurchased.ToString()"
                 Sub="@($"{_business.AccountsInEvaluation} {L["En evaluación"].Value.ToLowerInvariant()} · {_business.AccountsFunded} {L["fondeadas"]} · {_business.AccountsFailed + _business.AccountsExpired} {L["quemadas"]}")" />
        <KpiCard Title="@L["Coste por cuenta fondeada"]" Value="@FormatMoney(_business.CostPerFundedAccount)" />
        <KpiCard Title="@L["Payout medio por fondeada"]" Value="@FormatMoney(_business.AvgPayoutPerFundedAccount)" />
        <KpiCard Title="@L["Payouts totales recibidos"]" Value="@FormatMoney(_business.TotalPayoutsReceived)" />
        <KpiCard Title="@L["Costes totales"]" Value="@FormatMoney(_business.TotalCosts)" />
    </div>
}

<script src="js/kpi-countup.js"></script>

@code {
    private BusinessKpis? _business;
    private TradingKpis? _trading;
    private List<MonthlyCashflowPoint>? _cashflow;
    private IReadOnlyList<DrawdownAlertDto>? _drawdownAlerts;
    private int _pendingEmotionCount;
    private IReadOnlyList<AccountComplianceStatusDto>? _compliance;

    private string RoiEmphasis => _business?.BusinessRoi switch
    {
        > 0 => "text-success",
        < 0 => "text-danger",
        _ => "",
    };

    [CascadingParameter]
    private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // La raíz "/" es AllowAnonymous: un visitante sin sesión ve la landing con toda la info del
        // producto (no se le fuerza al login). El usuario autenticado sí ve su dashboard aquí. La
        // redirección ocurre durante el prerender (SSR), antes de cargar KPIs — que requieren usuario.
        if (AuthState is not null)
        {
            var authState = await AuthState;
            if (authState.User.Identity?.IsAuthenticated != true)
            {
                Nav.NavigateTo("bienvenida");
                return;
            }
        }

        Currency.Changed += OnCurrencyChanged;
        _business = await KpiService.GetBusinessKpisAsync();
        _trading = await KpiService.GetTradingKpisAsync();
        _cashflow = (await KpiService.GetMonthlyCashflowAsync(months: 12)).ToList();

        var limits = await PlanService.GetLimitsAsync();
        _drawdownAlerts = limits.FullRiskModule ? await RiskAnalysisService.GetDrawdownAlertsAsync() : [];

        var today = DateOnly.FromDateTime(DateTime.UtcNow.Date);
        _pendingEmotionCount = (await PsychologyService.GetPendingAsync(today.AddDays(-14), today)).Count;
        _compliance = await RuleComplianceService.GetComplianceStatusAsync();
    }

    // Los KPI se calculan una vez en OnInitializedAsync; al cambiar de divisa solo hace falta
    // repintar con los mismos datos, no volver a consultarlos.
    private void OnCurrencyChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Currency.Changed -= OnCurrencyChanged;

    private static string FormatPercent(double? value) => value is null ? "—" : $"{value:P1}";
    private string FormatMoney(decimal? value) => Currency.Format(value);

    // El chip de la tarjeta refleja la peor de las tres reglas de la cuenta.
    private static ComplianceLevel WorstLevel(AccountComplianceStatusDto c)
    {
        var worst = c.DailyLossLevel;
        if (c.DrawdownLevel > worst) worst = c.DrawdownLevel;
        if (c.ConsistencyLevel is { } cl && cl > worst) worst = cl;
        return worst;
    }

    // Color del riel superior de la tarjeta de reglas: refleja la peor de las tres reglas.
    private static string RailClass(AccountComplianceStatusDto c) => WorstLevel(c) switch
    {
        ComplianceLevel.Red => "risk",
        ComplianceLevel.Yellow => "warn",
        _ => "ok",
    };

    private static string OverallStageClass(AccountComplianceStatusDto c) => WorstLevel(c) switch
    {
        ComplianceLevel.Red => "stage-failed",
        ComplianceLevel.Yellow => "stage-warn",
        _ => "stage-funded",
    };

    private string OverallStageText(AccountComplianceStatusDto c) => WorstLevel(c) switch
    {
        ComplianceLevel.Red => L["Riesgo"],
        ComplianceLevel.Yellow => L["Atención"],
        _ => "OK",
    };

    private static MarkupString Dot(ComplianceLevel level)
    {
        var color = level switch
        {
            ComplianceLevel.Red => "var(--danger)",
            ComplianceLevel.Yellow => "#d29922",
            _ => "var(--good)",
        };
        return new MarkupString($"<span class=\"compliance-dot\" style=\"background:{color}\"></span>");
    }
}
