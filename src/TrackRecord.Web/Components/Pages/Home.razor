@page "/"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@implements IDisposable
@inject IKpiService KpiService
@inject IRiskAnalysisService RiskAnalysisService
@inject IPlanService PlanService
@inject IPsychologyService PsychologyService
@inject IRuleComplianceService RuleComplianceService
@inject CurrencyState Currency
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

<PageTitle>Dashboard — @Brand.Name</PageTitle>

<h1>Dashboard</h1>
<p class="text-muted">@L["Visión general del negocio de fondeo y de tu operativa."]</p>

@if (_pendingEmotionCount > 0)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center">
        <span>@L["Tienes {0} trade(s) sin diario emocional — completarlo lleva menos de un minuto.", _pendingEmotionCount]</span>
        <a class="btn btn-sm btn-outline-primary" href="emotion-survey">@L["Registrar ahora"]</a>
    </div>
}

@if (_drawdownAlerts is { Count: > 0 })
{
    <div class="alert alert-danger">
        <strong><span class="alert-dot" aria-hidden="true"></span>@L["Aviso de drawdown:"]</strong>
        @foreach (var alert in _drawdownAlerts)
        {
            <div>@L["{0} — {1} del colchón de drawdown consumido (quedan {2}).", alert.AccountDisplayName, alert.ConsumedFraction.ToString("P0"), Currency.Format(alert.RemainingBuffer)]</div>
        }
    </div>
}

@if (_compliance is { Count: > 0 })
{
    <h2>@L["Semáforo de reglas"]</h2>
    <div class="rule-grid">
        @foreach (var c in _compliance)
        {
            <div class="rule-card">
                <div class="rule-head">
                    <b>@c.AccountDisplayName</b>
                    <span class="stage @OverallStageClass(c)">@OverallStageText(c)</span>
                </div>
                <div class="rule-row">
                    <span>@L["Pérdida diaria"]</span>
                    <span class="rule-val">
                        @Dot(c.DailyLossLevel)
                        @(c.DailyLossLimit is null ? L["N/A"].Value : L["quedan {0}", Currency.Format(c.DailyLossRemaining ?? 0, 0)].Value)
                    </span>
                </div>
                <div class="rule-row">
                    <span>@L["Drawdown"]</span>
                    <span class="rule-val">@Dot(c.DrawdownLevel) @L["colchón {0}", Currency.Format(c.DrawdownRemainingBuffer, 0)]</span>
                </div>
                <div class="rule-row">
                    <span>@L["Consistencia"]</span>
                    <span class="rule-val">
                        @if (c.ConsistencyLevel is null)
                        {
                            @L["N/A"]
                        }
                        else
                        {
                            @Dot(c.ConsistencyLevel.Value)
                            @($"{c.ConsistencyTopDayFraction:P0} / {c.ConsistencyMaxDayFraction:P0}")
                        }
                    </span>
                </div>
            </div>
        }
    </div>
}

@if (_business is null || _trading is null)
{
    <h2>@L["Negocio de fondeo"]</h2>
    <div class="kpi-grid">
        @for (var i = 0; i < 8; i++)
        {
            <div class="stat-tile">
                <div class="skeleton skeleton-label"></div>
                <div class="skeleton skeleton-value"></div>
            </div>
        }
    </div>
}
else
{
    <h2>@L["Negocio de fondeo"]</h2>
    <div class="kpi-grid">
        <KpiCard Title="@L["Cashflow neto"]" Value="@Currency.Format(_business.NetCashflow)"
                 Emphasis="@(_business.NetCashflow >= 0 ? "text-success" : "text-danger")"
                 Sub="@($"{Currency.Format(_business.TotalPayoutsReceived, 0)} payouts − {Currency.Format(_business.TotalCosts, 0)} {L["Costes"].Value.ToLowerInvariant()}")" />
        <KpiCard Title="@L["ROI del negocio"]" Value="@FormatPercent(_business.BusinessRoi)" Emphasis="@RoiEmphasis" />
        <KpiCard Title="Pass rate" Value="@FormatPercent(_business.PassRate)" />
        <KpiCard Title="@L["Cuentas compradas"]" Value="@_business.AccountsPurchased.ToString()"
                 Sub="@($"{_business.AccountsInEvaluation} {L["En evaluación"].Value.ToLowerInvariant()} · {_business.AccountsFunded} {L["fondeadas"]} · {_business.AccountsFailed + _business.AccountsExpired} {L["quemadas"]}")" />
        <KpiCard Title="@L["Coste por cuenta fondeada"]" Value="@FormatMoney(_business.CostPerFundedAccount)" />
        <KpiCard Title="@L["Payout medio por fondeada"]" Value="@FormatMoney(_business.AvgPayoutPerFundedAccount)" />
    </div>

    <h2>@L["Evolución"]</h2>
    <div class="chart-grid">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@L["Cashflow mensual"]</h5>
                <p class="chart-caption">@L["Lo que entra (payouts) contra lo que se gasta en evaluaciones y cuotas, mes a mes, con el neto acumulado del negocio."]</p>
                @if (_cashflow is { Count: > 0 })
                {
                    <CashflowChart Points="_cashflow" Currency="Currency.Current" />
                }
                else
                {
                    <EmptyState Title="@L["Sin movimientos todavía"]"
                                Text="@L["Registra costes y payouts en tus cuentas para ver el cashflow mensual."]" />
                }
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@L["Curva de equity (trading)"]</h5>
                <p class="chart-caption">@L["P&L neto acumulado de todos tus trades cerrados, día a día."]</p>
                @if (_equity is { Count: > 1 })
                {
                    <EquityChart Points="_equity" Currency="Currency.Current" />
                }
                else
                {
                    <EmptyState Title="@L["Sin trades suficientes"]"
                                Text="@L["Cuando registres trades cerrados, la curva de equity aparecerá aquí."]" />
                }
            </div>
        </div>
    </div>

    <h2>@L["Operativa (trading)"]</h2>
    @if (_trading.TotalTrades == 0)
    {
        <EmptyState Title="@L["Todavía no hay trades registrados"]"
                    Text="@L["Importa el CSV de Tradovate o NinjaTrader 8, o añade trades manualmente desde la ficha de una cuenta."]" />
    }
    else
    {
        <div class="kpi-grid">
            <KpiCard Title="Net P&amp;L" Value="@Currency.Format(_trading.NetPnL)"
                     Emphasis="@(_trading.NetPnL >= 0 ? "text-success" : "text-danger")"
                     Sub="@($"{Currency.Format(_trading.GrossProfit, 0)} gross profit · {Currency.Format(_trading.GrossLoss, 0)} gross loss")" />
            <KpiCard Title="Win rate" Value="@FormatPercent(_trading.WinRate)"
                     Sub="@L["{0} trades cerrados", _trading.TotalTrades]" />
            <KpiCard Title="Profit factor" Value="@FormatRatio(_trading.ProfitFactor)" />
            <KpiCard Title="@L["Expectancy / trade"]" Value="@FormatMoney(_trading.Expectancy)" />
            <KpiCard Title="Payoff ratio" Value="@FormatRatio(_trading.PayoffRatio)" />
            <KpiCard Title="@L["R-múltiplo medio"]" Value="@(_trading.AvgRMultiple?.ToString("0.00") ?? "—")" />
            <KpiCard Title="@L["Máx. drawdown"]" Value="@Currency.Format(_trading.MaxDrawdown)" Emphasis="text-danger" />
            <KpiCard Title="@L["Racha máx. pérdidas"]" Value="@_trading.MaxConsecutiveLosses.ToString()" />
        </div>

        @if (_tagPerformance is { Count: > 0 })
        {
            <h2 class="mt-4">@L["Rendimiento por tag"]</h2>
            <div class="tag-panel">
                <div class="tag-row tag-head">
                    <span>Tag</span>
                    <span class="text-end">@L["Trades cerrados"]</span>
                    <span class="text-end">Win rate</span>
                    <span class="text-end">Profit factor</span>
                    <span class="text-end">Net P&amp;L</span>
                </div>
                @foreach (var tag in _tagPerformance)
                {
                    <div class="tag-row">
                        <span><span class="tag-pill">@tag.Tag</span></span>
                        <span class="text-end mono">@tag.TotalTrades</span>
                        <span class="text-end mono">@FormatPercent(tag.WinRate)</span>
                        <span class="text-end mono">@FormatRatio(tag.ProfitFactor)</span>
                        <span class="text-end mono @(tag.NetPnL >= 0 ? "text-success" : "text-danger")">@Currency.Format(tag.NetPnL)</span>
                    </div>
                }
            </div>
        }

        @if (_bestHours.Count > 0 || _worstHours.Count > 0)
        {
            <h2 class="mt-4">@L["Mejores y peores franjas horarias"]</h2>
            <div class="hours-panel">
                <div class="hours-cols">
                    <div class="hours-col">
                        <h4 class="text-success">@L["Mejor expectancy"]</h4>
                        @foreach (var p in _bestHours)
                        {
                            <div class="hours-row">
                                <span>@HourLabel(p)</span>
                                <span class="mono text-success">@Currency.Format(p.Expectancy ?? 0) <span class="hours-n">(n=@p.TradeCount)</span></span>
                            </div>
                        }
                    </div>
                    <div class="hours-col">
                        <h4 class="text-danger">@L["Peor expectancy"]</h4>
                        @foreach (var p in _worstHours)
                        {
                            <div class="hours-row">
                                <span>@HourLabel(p)</span>
                                <span class="mono text-danger">@Currency.Format(p.Expectancy ?? 0) <span class="hours-n">(n=@p.TradeCount)</span></span>
                            </div>
                        }
                    </div>
                </div>
                @if (_durationAsymmetry is { AvgWinDurationMinutes: not null, AvgLossDurationMinutes: not null })
                {
                    <div class="hours-foot">
                        @L["Duración media: ganadores {0} min vs perdedores {1} min.", _durationAsymmetry.AvgWinDurationMinutes.Value.ToString("0"), _durationAsymmetry.AvgLossDurationMinutes.Value.ToString("0")]
                    </div>
                }
            </div>
        }

        <h2 class="mt-4">@L["Calidad de ejecución (MAE/MFE)"]</h2>
        @if (_executionQuality is { TradesWithData: > 0 })
        {
            <p class="chart-caption">@L["Basado en {0} trade(s) con excursión registrada ({1} de tu histórico).", _executionQuality.TradesWithData, _executionQuality.CoveragePct.ToString("P0")]</p>
            <div class="kpi-grid">
                <KpiCard Title="@L["Ratio de captura"]" Value="@(_executionQuality.AvgCaptureRatio is null ? "—" : _executionQuality.AvgCaptureRatio.Value.ToString("P0"))" />
                <KpiCard Title="@L["MAE medio (R)"]" Value="@(_executionQuality.AvgMaeR is null ? "—" : $"{_executionQuality.AvgMaeR:0.00}R")" Emphasis="text-danger" />
                <KpiCard Title="@L["MFE medio (R)"]" Value="@(_executionQuality.AvgMfeR is null ? "—" : $"{_executionQuality.AvgMfeR:0.00}R")" Emphasis="text-success" />
            </div>
            <p class="text-muted small mt-2 mb-0">
                @L["Ratio de captura = cuánto del movimiento a favor máximo (MFE) terminaste quedándote — 100% es salir en el mejor punto posible."]
            </p>
        }
        else
        {
            <EmptyState Title="@L["Sin datos de excursión todavía"]"
                        Text="@L["Al añadir un trade manualmente (o mapear las columnas al importar CSV), registra la pérdida y ganancia flotante máxima para desbloquear esta métrica."]" />
        }
    }
}

<script src="js/kpi-countup.js"></script>

@code {
    private BusinessKpis? _business;
    private TradingKpis? _trading;
    private List<MonthlyCashflowPoint>? _cashflow;
    private List<EquityCurvePoint>? _equity;
    private IReadOnlyList<DrawdownAlertDto>? _drawdownAlerts;
    private IReadOnlyList<TagPerformanceDto>? _tagPerformance;
    private int _pendingEmotionCount;
    private IReadOnlyList<AccountComplianceStatusDto>? _compliance;
    private List<TimeOfDayPerformancePoint> _bestHours = [];
    private List<TimeOfDayPerformancePoint> _worstHours = [];
    private DurationAsymmetryDto? _durationAsymmetry;
    private ExecutionQualityDto? _executionQuality;

    private string RoiEmphasis => _business?.BusinessRoi switch
    {
        > 0 => "text-success",
        < 0 => "text-danger",
        _ => "",
    };

    [CascadingParameter]
    private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // La raíz "/" es AllowAnonymous: un visitante sin sesión ve la landing con toda la info del
        // producto (no se le fuerza al login). El usuario autenticado sí ve su dashboard aquí. La
        // redirección ocurre durante el prerender (SSR), antes de cargar KPIs — que requieren usuario.
        if (AuthState is not null)
        {
            var authState = await AuthState;
            if (authState.User.Identity?.IsAuthenticated != true)
            {
                Nav.NavigateTo("bienvenida");
                return;
            }
        }

        Currency.Changed += OnCurrencyChanged;
        _business = await KpiService.GetBusinessKpisAsync();
        _trading = await KpiService.GetTradingKpisAsync();
        _cashflow = (await KpiService.GetMonthlyCashflowAsync(months: 12)).ToList();
        _equity = (await KpiService.GetEquityCurveAsync()).ToList();
        _tagPerformance = await KpiService.GetTagPerformanceAsync();

        var heatmap = (await KpiService.GetTimeOfDayHeatmapAsync()).Where(p => p.TradeCount >= 3).ToList();
        _bestHours = heatmap.OrderByDescending(p => p.Expectancy).Take(5).ToList();
        _worstHours = heatmap.OrderBy(p => p.Expectancy).Take(5).ToList();
        _durationAsymmetry = await KpiService.GetDurationAsymmetryAsync();
        _executionQuality = await KpiService.GetExecutionQualityAsync();

        var limits = await PlanService.GetLimitsAsync();
        _drawdownAlerts = limits.FullRiskModule ? await RiskAnalysisService.GetDrawdownAlertsAsync() : [];

        var today = DateOnly.FromDateTime(DateTime.UtcNow.Date);
        _pendingEmotionCount = (await PsychologyService.GetPendingAsync(today.AddDays(-14), today)).Count;
        _compliance = await RuleComplianceService.GetComplianceStatusAsync();
    }

    // Los KPI se calculan una vez en OnInitializedAsync; al cambiar de divisa solo hace falta
    // repintar con los mismos datos, no volver a consultarlos.
    private void OnCurrencyChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Currency.Changed -= OnCurrencyChanged;

    private static string HourLabel(TimeOfDayPerformancePoint p) =>
        $"{DayName(p.DayOfWeek)} {p.Hour:00}:00";

    private static string DayName(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday => "Lun",
        DayOfWeek.Tuesday => "Mar",
        DayOfWeek.Wednesday => "Mié",
        DayOfWeek.Thursday => "Jue",
        DayOfWeek.Friday => "Vie",
        DayOfWeek.Saturday => "Sáb",
        _ => "Dom",
    };

    private static string FormatPercent(double? value) => value is null ? "—" : $"{value:P1}";
    private static string FormatRatio(double? value) => value is null ? "—" : value.Value.ToString("0.00");
    private string FormatMoney(decimal? value) => Currency.Format(value);

    // El chip de la tarjeta refleja la peor de las tres reglas de la cuenta.
    private static ComplianceLevel WorstLevel(AccountComplianceStatusDto c)
    {
        var worst = c.DailyLossLevel;
        if (c.DrawdownLevel > worst) worst = c.DrawdownLevel;
        if (c.ConsistencyLevel is { } cl && cl > worst) worst = cl;
        return worst;
    }

    private static string OverallStageClass(AccountComplianceStatusDto c) => WorstLevel(c) switch
    {
        ComplianceLevel.Red => "stage-failed",
        ComplianceLevel.Yellow => "stage-warn",
        _ => "stage-funded",
    };

    private string OverallStageText(AccountComplianceStatusDto c) => WorstLevel(c) switch
    {
        ComplianceLevel.Red => L["Riesgo"],
        ComplianceLevel.Yellow => L["Atención"],
        _ => "OK",
    };

    private static MarkupString Dot(ComplianceLevel level)
    {
        var color = level switch
        {
            ComplianceLevel.Red => "var(--danger)",
            ComplianceLevel.Yellow => "#d29922",
            _ => "var(--good)",
        };
        return new MarkupString($"<span class=\"compliance-dot\" style=\"background:{color}\"></span>");
    }
}
