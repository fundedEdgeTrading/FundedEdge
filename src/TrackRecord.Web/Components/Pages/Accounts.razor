@page "/accounts"
@rendermode InteractiveServer
@implements IDisposable
@inject ITradingAccountService AccountService
@inject IPropFirmService PropFirmService
@inject IEvaluationProgramService ProgramService
@inject IRuleComplianceService ComplianceService
@inject CurrencyState Currency
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Cuentas"] — @Brand.Name</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@L["Cuentas de fondeo"]</h1>
    <button class="btn btn-primary" @onclick="ToggleCreateForm">@(_showCreateForm ? L["Cancelar"] : L["+ Nueva cuenta"])</button>
</div>

@if (_errorMessage is not null)
{
    <div class="alert alert-danger">@_errorMessage</div>
}

@if (_showCreateForm)
{
    <div class="form-card mb-4 mt-3">
        <EditForm Model="_form" OnValidSubmit="CreateAsync">
            <DataAnnotationsValidator />

            <div class="form-head">
                <h3 class="form-title">@L["Nueva cuenta"]</h3>
                <p>@L["Elige la firma y el programa: las reglas se rellenan solas. El modo manual pide las reglas a mano."]</p>
            </div>

            <fieldset class="fgroup">
                <legend>1 · @L["Identificación"]</legend>
                <p class="gdesc">@L["Qué cuenta es y de quién."]</p>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">@L["Firma"] <span class="req">*</span></label>
                        <InputSelect class="form-select" @bind-Value="_form.PropFirmId" @bind-Value:after="OnFirmChangedAsync">
                            <option value="">@L["Selecciona…"]</option>
                            @if (_firms is not null)
                            {
                                @foreach (var firm in _firms)
                                {
                                    <option value="@firm.Id">@firm.Name</option>
                                }
                            }
                        </InputSelect>
                        <ValidationMessage For="() => _form.PropFirmId" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">@L["Programa"]</label>
                        <InputSelect class="form-select" @bind-Value="_form.EvaluationProgramId" @bind-Value:after="OnProgramChangedAsync"
                                     disabled="@(_programs is null || _programs.Count == 0)">
                            <option value="">@(_form.PropFirmId is null ? L["Selecciona una firma primero"] : L["Personalizado (manual)"])</option>
                            @if (_programs is not null)
                            {
                                @foreach (var p in _programs)
                                {
                                    <option value="@p.Id">@p.Name (@Currency.Format(p.AccountSize, 0))</option>
                                }
                            }
                        </InputSelect>
                        <div class="form-hint">@L["Rellena las reglas automáticamente"]</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">@L["Nombre / alias"] <span class="req">*</span></label>
                        <InputText class="form-control" @bind-Value="_form.DisplayName" placeholder="Apex 50K #3" />
                        <div class="form-hint">@L["Como quieras verla en tus listados"]</div>
                        <ValidationMessage For="() => _form.DisplayName" />
                    </div>
                </div>
            </fieldset>

            <fieldset class="fgroup">
                <legend>2 · @L["Reglas del programa"]</legend>
                @if (_selectedProgram is not null)
                {
                    <p class="gdesc">@L["Autocompletadas desde"] <b>@_selectedProgram.Name</b>. @L["Ficha técnica de referencia:"]</p>
                    <div class="spec">
                        <div class="spec-head">
                            <b>@_selectedProgram.Name — @(_firms?.FirstOrDefault(f => f.Id == _form.PropFirmId)?.Name)</b>
                            <span class="stage stage-eval">@L["Ficha del programa"]</span>
                        </div>
                        <div class="spec-cols">
                            <div class="spec-col">
                                <h4>@L["Evaluación"]</h4>
                                <dl>
                                    <div class="kv2"><dt>@L["Tamaño"]</dt><dd>@Currency.Format(_selectedProgram.AccountSize, 0)</dd></div>
                                    <div class="kv2"><dt>Profit target</dt><dd>@Currency.Format(_selectedProgram.ProfitTarget)</dd></div>
                                    <div class="kv2"><dt>Max drawdown</dt><dd>@Currency.Format(_selectedProgram.MaxDrawdown) · @_selectedProgram.DrawdownType</dd></div>
                                    @if (_selectedProgram.DailyLossLimit.HasValue)
                                    {
                                        <div class="kv2"><dt>@L["Daily loss limit"]</dt><dd>@Currency.Format(_selectedProgram.DailyLossLimit.Value)</dd></div>
                                    }
                                    @if (_selectedProgram.MinTradingDays.HasValue)
                                    {
                                        <div class="kv2"><dt>@L["Días mínimos"]</dt><dd>@_selectedProgram.MinTradingDays</dd></div>
                                    }
                                    @if (_selectedProgram.ConsistencyMaxDayFraction.HasValue)
                                    {
                                        <div class="kv2"><dt>@L["Consistencia máx."]</dt><dd>@_selectedProgram.ConsistencyMaxDayFraction.Value.ToString("P0")</dd></div>
                                    }
                                    <div class="kv2"><dt>@L["Coste eval."]</dt><dd>@Currency.Format(_selectedProgram.EvaluationCost)</dd></div>
                                    @if (_selectedProgram.ActivationCost > 0)
                                    {
                                        <div class="kv2"><dt>@L["Coste activación"]</dt><dd>@Currency.Format(_selectedProgram.ActivationCost)</dd></div>
                                    }
                                </dl>
                            </div>
                            <div class="spec-col">
                                <h4>@L["Fase fondeada"]</h4>
                                <dl>
                                    <div class="kv2"><dt>Drawdown</dt><dd>@(_selectedProgram.FundedDrawdownType?.ToString() ?? _selectedProgram.DrawdownType.ToString())</dd></div>
                                    <div class="kv2"><dt>Max drawdown</dt><dd>@Currency.Format(_selectedProgram.FundedMaxDrawdown ?? _selectedProgram.MaxDrawdown)</dd></div>
                                    @if ((_selectedProgram.FundedDailyLossLimit ?? _selectedProgram.DailyLossLimit).HasValue)
                                    {
                                        <div class="kv2"><dt>Daily loss</dt><dd>@Currency.Format((_selectedProgram.FundedDailyLossLimit ?? _selectedProgram.DailyLossLimit)!.Value)</dd></div>
                                    }
                                    @if (_selectedProgram.FundedMinTradingDays.HasValue)
                                    {
                                        <div class="kv2"><dt>@L["Días mínimos"]</dt><dd>@_selectedProgram.FundedMinTradingDays</dd></div>
                                    }
                                </dl>
                            </div>
                            <div class="spec-col">
                                <h4>Payout</h4>
                                <dl>
                                    <div class="kv2"><dt>Split trader</dt><dd>@_selectedProgram.PayoutSplitTraderPct.ToString("P0")</dd></div>
                                    @if (_selectedProgram.PayoutMaxProfitPct.HasValue)
                                    {
                                        <div class="kv2"><dt>@L["Cap retiro"]</dt><dd>@_selectedProgram.PayoutMaxProfitPct.Value.ToString("P0") @L["del profit"]</dd></div>
                                    }
                                    @if (_selectedProgram.PayoutMinDaysBetween.HasValue)
                                    {
                                        <div class="kv2"><dt>@L["Días entre payouts"]</dt><dd>@_selectedProgram.PayoutMinDaysBetween</dd></div>
                                    }
                                </dl>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <p class="gdesc">@L["Sin programa seleccionado: define las reglas a mano."]</p>
                    <div class="row g-3">
                        <div class="col-md-3 col-6">
                            <label class="form-label">@L["Tamaño cuenta"]</label>
                            <div class="igroup">
                                <span class="prefix">@Currency.Symbol</span>
                                <InputNumber class="form-control" @bind-Value="_form.AccountSize" />
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <label class="form-label">Profit target</label>
                            <div class="igroup">
                                <span class="prefix">@Currency.Symbol</span>
                                <InputNumber class="form-control" @bind-Value="_form.ProfitTarget" />
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <label class="form-label">Max drawdown</label>
                            <div class="igroup">
                                <span class="prefix">@Currency.Symbol</span>
                                <InputNumber class="form-control" @bind-Value="_form.MaxDrawdown" />
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <label class="form-label">@L["Tipo de drawdown"]</label>
                            <div class="currency-toggle seg-block" role="group" aria-label="@L["Tipo de drawdown"]">
                                @foreach (var v in Enum.GetValues<DrawdownType>())
                                {
                                    <button type="button"
                                            class="currency-option @(_form.DrawdownType == v ? "active" : null)"
                                            @onclick="() => _form.DrawdownType = v">@v</button>
                                }
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <label class="form-label">@L["Coste evaluación"]</label>
                            <div class="igroup">
                                <span class="prefix">@Currency.Symbol</span>
                                <InputNumber class="form-control" @bind-Value="_form.EvaluationCost" />
                            </div>
                        </div>
                    </div>
                }
            </fieldset>

            <fieldset class="fgroup">
                <legend>3 · @L["Compra y plataforma"]</legend>
                <p class="gdesc">@L["Cuándo la compraste y en qué plataforma operas — los trades se importan por CSV desde la ficha de la cuenta."]</p>
                <div class="row g-3">
                    <div class="col-md-3 col-6">
                        <label class="form-label">@L["Fecha de compra"]</label>
                        <InputDate class="form-control" @bind-Value="_form.PurchasedOn" />
                    </div>
                    <div class="col-md-3 col-6">
                        <label class="form-label">@L["Plataforma"]</label>
                        <InputSelect class="form-select" @bind-Value="_form.Feed">
                            @foreach (var v in Enum.GetValues<DataFeedType>())
                            {
                                <option value="@v">@v</option>
                            }
                        </InputSelect>
                    </div>
                </div>
            </fieldset>

            <div class="form-foot">
                <span class="status">@L["Los campos marcados con"] <span class="req">*</span> @L["son obligatorios"]</span>
                <div class="actions">
                    <button type="button" class="btn btn-outline-secondary" @onclick="ToggleCreateForm">@L["Cancelar"]</button>
                    <button type="submit" class="btn btn-primary">@L["Guardar cuenta"]</button>
                </div>
            </div>
        </EditForm>
    </div>
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div class="stage-filter">
        <button type="button" class="form-select stage-filter-btn" @onclick="() => _filterOpen = !_filterOpen">
            @StageFilterLabel
        </button>
        @if (_filterOpen)
        {
            <div class="stage-filter-panel">
                @foreach (var v in Enum.GetValues<AccountStage>())
                {
                    <label class="stage-filter-option">
                        <input type="checkbox" checked="@_stageFilters.Contains(v)" @onchange="() => ToggleStage(v)" />
                        <span>@v</span>
                    </label>
                }
                <button type="button" class="stage-filter-clear" @onclick="ClearStageFilters">@L["Todas las etapas"]</button>
            </div>
        }
    </div>
    <div class="currency-toggle view-toggle" role="group" aria-label="@L["Vista"]">
        <button type="button" class="currency-option @(_cardView ? "active" : null)" @onclick="() => _cardView = true">@L["Tarjetas"]</button>
        <button type="button" class="currency-option @(!_cardView ? "active" : null)" @onclick="() => _cardView = false">@L["Tabla"]</button>
    </div>
</div>

@if (_accounts is null)
{
    <div class="account-grid" aria-label="@L["Cargando…"]">
        @for (var i = 0; i < 3; i++)
        {
            <div class="card"><div class="card-body">
                <div class="skeleton skeleton-label"></div>
                <div class="skeleton skeleton-value mb-3"></div>
                <div class="skeleton skeleton-label" style="width:85%"></div>
                <div class="skeleton skeleton-label" style="width:70%"></div>
            </div></div>
        }
    </div>
}
else if (_accounts.Count == 0)
{
    <EmptyState Title="@L["No hay cuentas que coincidan con el filtro"]"
                Text="@L["Crea tu primera cuenta de fondeo y empieza a trackear objetivos, drawdown y payouts."]">
        <button class="btn btn-primary" @onclick="ToggleCreateForm">@L["+ Nueva cuenta"]</button>
    </EmptyState>
}
else if (_cardView)
{
    <div class="account-grid">
        @foreach (var a in _accounts)
        {
            <AccountCard Account="a" Compliance="@_compliance.GetValueOrDefault(a.Id)" OnOpen="GoToDetail" />
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>@L["Cuenta"]</th>
                    <th>@L["Etapa"]</th>
                    <th>@L["Tamaño"]</th>
                    <th>@L["Comprada"]</th>
                    <th class="text-end">@L["Costes"]</th>
                    <th class="text-end">Payouts</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in _accounts)
                {
                    <tr style="cursor:pointer" @onclick="() => GoToDetail(a.Id)">
                        <td class="row-title"><b>@a.DisplayName</b><span>@a.PropFirmName</span></td>
                        <td><span class="stage @StageBadgeClass(a.Stage)">@a.Stage</span></td>
                        <td>@Currency.Format(a.AccountSize, 0)</td>
                        <td class="num-muted">@a.PurchasedOn.ToString("d")</td>
                        <td class="text-end @(a.TotalCosts == 0 ? "num-muted" : null)">@Currency.Format(a.TotalCosts)</td>
                        <td class="text-end @(a.TotalPayoutsReceived == 0 ? "num-muted" : null)">@Currency.Format(a.TotalPayoutsReceived)</td>
                        <td class="chev">›</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_toastMessage is not null)
{
    <div class="app-toast" role="status">
        <div class="tick">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
        </div>
        <div><b>@L["Cuenta creada"]</b><span>@_toastMessage</span></div>
    </div>
}

@code {
    private List<TradingAccountListItemDto>? _allAccounts;
    private List<TradingAccountListItemDto>? _accounts;
    private List<PropFirmDto>? _firms;
    private List<EvaluationProgramDto>? _programs;
    private EvaluationProgramDto? _selectedProgram;
    private bool _showCreateForm;
    private bool _cardView = true;
    private bool _filterOpen;
    // Por defecto solo se ven las cuentas "activas" (fondeadas o en evaluación) — igual que la
    // definición de "cuenta activa" del resto de la app (límites de plan, FAQ de precios).
    private readonly HashSet<AccountStage> _stageFilters = [AccountStage.Funded, AccountStage.Evaluation];
    private CreateAccountFormModel _form = new();
    private string? _errorMessage;
    private string? _toastMessage;
    private Dictionary<Guid, AccountComplianceStatusDto> _compliance = [];

    private string StageFilterLabel
    {
        get
        {
            var allStages = Enum.GetValues<AccountStage>();
            if (_stageFilters.Count == 0 || _stageFilters.Count == allStages.Length)
            {
                return L["Todas las etapas"];
            }
            return _stageFilters.Count == 1
                ? _stageFilters.First().ToString()
                : L["{0} etapas seleccionadas", _stageFilters.Count];
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Currency.Changed += OnCurrencyChanged;
        _firms = (await PropFirmService.GetAllAsync()).ToList();
        await LoadAsync();
    }

    private void OnCurrencyChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Currency.Changed -= OnCurrencyChanged;

    private async Task LoadAsync()
    {
        _allAccounts = (await AccountService.GetAllAsync()).ToList();
        _compliance = (await ComplianceService.GetComplianceStatusAsync()).ToDictionary(c => c.AccountId);
        ApplyStageFilter();
    }

    private void ApplyStageFilter()
    {
        _accounts = _stageFilters.Count == 0
            ? _allAccounts
            : _allAccounts?.Where(a => _stageFilters.Contains(a.Stage)).ToList();
    }

    private void ToggleStage(AccountStage stage)
    {
        if (!_stageFilters.Remove(stage)) _stageFilters.Add(stage);
        ApplyStageFilter();
    }

    private void ClearStageFilters()
    {
        _stageFilters.Clear();
        _filterOpen = false;
        ApplyStageFilter();
    }

    private void ToggleCreateForm() => _showCreateForm = !_showCreateForm;

    private void GoToDetail(Guid id) => Nav.NavigateTo($"/accounts/{id}");

    private async Task OnFirmChangedAsync()
    {
        _form.EvaluationProgramId = null;
        _selectedProgram = null;
        _programs = null;

        if (_form.PropFirmId is null) return;
        _programs = (await ProgramService.GetByFirmAsync(_form.PropFirmId.Value)).ToList();
    }

    private async Task OnProgramChangedAsync()
    {
        if (_form.EvaluationProgramId is null)
        {
            _selectedProgram = null;
            return;
        }
        _selectedProgram = await ProgramService.GetByIdAsync(_form.EvaluationProgramId.Value);
        if (_selectedProgram is null) return;

        // Autocompletar campos de reglas desde el programa seleccionado
        _form.AccountSize    = _selectedProgram.AccountSize;
        _form.ProfitTarget   = _selectedProgram.ProfitTarget;
        _form.MaxDrawdown    = _selectedProgram.MaxDrawdown;
        _form.DrawdownType   = _selectedProgram.DrawdownType;
        _form.EvaluationCost = _selectedProgram.EvaluationCost;
    }

    private async Task CreateAsync()
    {
        if (_form.PropFirmId is null) return;

        var request = new CreateTradingAccountRequest(
            _form.PropFirmId.Value,
            _form.DisplayName,
            string.IsNullOrWhiteSpace(_form.ExternalAccountId) ? null : _form.ExternalAccountId,
            _form.AccountSize,
            _form.ProfitTarget,
            _form.MaxDrawdown,
            _form.DrawdownType,
            _form.Feed,
            _form.PurchasedOn,
            _form.EvaluationCost,
            null,
            _form.EvaluationProgramId);

        try
        {
            await AccountService.CreateAsync(request);
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
            return;
        }

        _errorMessage = null;
        var createdName = _form.DisplayName;
        _form = new CreateAccountFormModel();
        _programs = null;
        _selectedProgram = null;
        _showCreateForm = false;
        await LoadAsync();
        await ShowToastAsync($"«{createdName}» {L["ya aparece en tu listado."]}");
    }

    private async Task ShowToastAsync(string message)
    {
        _toastMessage = message;
        StateHasChanged();
        await Task.Delay(4000);
        _toastMessage = null;
        StateHasChanged();
    }

    private static string StageBadgeClass(AccountStage stage) => stage switch
    {
        AccountStage.Evaluation => "stage-eval",
        AccountStage.Funded => "stage-funded",
        AccountStage.Failed => "stage-failed",
        AccountStage.Withdrawn => "stage-muted",
        AccountStage.Expired => "stage-warn",
        _ => "stage-eval",
    };

    private class CreateAccountFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public Guid? PropFirmId { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public string DisplayName { get; set; } = "";

        public Guid? EvaluationProgramId { get; set; }
        public string? ExternalAccountId { get; set; }
        public decimal AccountSize { get; set; } = 50000;
        public decimal ProfitTarget { get; set; } = 3000;
        public decimal MaxDrawdown { get; set; } = 2000;
        public DrawdownType DrawdownType { get; set; } = DrawdownType.Trailing;
        public DataFeedType Feed { get; set; } = DataFeedType.Manual;
        public DateOnly PurchasedOn { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public decimal? EvaluationCost { get; set; }
    }
}
