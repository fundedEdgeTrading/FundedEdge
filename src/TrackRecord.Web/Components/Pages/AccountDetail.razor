    }

    private async Task ConfirmAndDeleteAccountAsync()
    {
        if (_account is null || _confirmDialog is null) return;

        var message = L["Se eliminará la cuenta «{0}» junto con todos sus datos asociados: {1} trade(s), {2} coste(s), {3} payout(s) y {4} evento(s) de ciclo de vida.",
            _account.DisplayName, _account.Trades.Count, _account.Costs.Count, _account.Payouts.Count, _account.Events.Count].Value
            + "\n\n" + L["Esta acción no se puede deshacer."].Value;

        var confirmed = await _confirmDialog.ShowAsync(L["Eliminar cuenta"], message, confirmText: L["Eliminar cuenta"]);
        if (!confirmed) return;

        await AccountService.DeleteAsync(AccountId);
        Nav.NavigateTo("/accounts");
    }

    private async Task OnCsvFileSelectedAsync(InputFileChangeEventArgs e)
    {
        _csvImporting = true;
        _csvImportSummary = null;
        StateHasChanged();

        try
        {
            const long maxFileSizeBytes = 10 * 1024 * 1024; // 10 MB — de sobra para un export de trades
            await using var stream = e.File.OpenReadStream(maxFileSizeBytes);
            using var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);
            buffer.Position = 0;

            _csvImportSummary = await CsvImportService.ImportAsync(AccountId, buffer);
        }
        finally
        {
            _csvImporting = false;
        }

        await LoadAsync();
    }

    private async Task OnGenericCsvFileSelectedAsync(InputFileChangeEventArgs e)
    {
        _genericCsvError = null;
        _genericCsvSummary = null;
        _genericCsvHeaders = null;
        _genericCsvBuffer?.Dispose();
        _genericCsvBuffer = null;

        try
        {
            const long maxFileSizeBytes = 10 * 1024 * 1024;
            await using var stream = e.File.OpenReadStream(maxFileSizeBytes);
            var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);
            buffer.Position = 0;

            _genericCsvBuffer = buffer;
            _genericCsvHeaders = await GenericCsvImportService.ReadHeadersAsync(buffer, default);
            _genericMapping = GuessMapping(_genericCsvHeaders);
        }
        catch (Exception ex)
        {
            _genericCsvError = ex.Message;
        }
    }

    private async Task ImportGenericCsvAsync()
    {
        if (_genericCsvBuffer is null) return;

        _genericCsvImporting = true;
        _genericCsvError = null;
        _genericCsvSummary = null;
        StateHasChanged();

        try
        {
            _genericCsvBuffer.Position = 0;
            var mapping = new GenericCsvColumnMapping(
                _genericMapping.Symbol, _genericMapping.Direction, _genericMapping.Quantity,
                _genericMapping.EntryPrice, _genericMapping.ExitPrice, _genericMapping.OpenedAt, _genericMapping.ClosedAt,
                _genericMapping.GrossPnL,
                string.IsNullOrEmpty(_genericMapping.Commissions) ? null : _genericMapping.Commissions,
                string.IsNullOrEmpty(_genericMapping.Tags) ? null : _genericMapping.Tags,
                string.IsNullOrEmpty(_genericMapping.MaxAdverseExcursion) ? null : _genericMapping.MaxAdverseExcursion,
                string.IsNullOrEmpty(_genericMapping.MaxFavorableExcursion) ? null : _genericMapping.MaxFavorableExcursion);

            _genericCsvSummary = await GenericCsvImportService.ImportAsync(AccountId, _genericCsvBuffer, mapping);
        }
        catch (Exception ex)
        {
            _genericCsvError = ex.Message;
        }
        finally
        {
            _genericCsvImporting = false;
        }

        await LoadAsync();
    }

    /// <summary>
    /// Adivina el mapeo inicial buscando alias habituales entre las cabeceras del CSV subido, para
    /// que el &lt;select&gt; no arranque en un valor vacío que no exista entre las opciones (el
    /// primer intento de importar sin tocar nada debería funcionar para exports razonablemente
    /// estándar). El usuario puede corregir cualquier campo antes de importar.
    /// </summary>
    private static GenericCsvMappingFormModel GuessMapping(IReadOnlyList<string> headers)
    {
        string Guess(string[] aliases) =>
            headers.FirstOrDefault(h => aliases.Any(a => string.Equals(a, h, StringComparison.OrdinalIgnoreCase)))
            ?? headers[0];

        string? GuessOptional(string[] aliases) =>
            headers.FirstOrDefault(h => aliases.Any(a => string.Equals(a, h, StringComparison.OrdinalIgnoreCase)));

        return new GenericCsvMappingFormModel
        {
            Symbol = Guess(["Symbol", "Instrument", "Ticker"]),
            Direction = Guess(["Direction", "Side", "Market pos.", "Market Position"]),
            Quantity = Guess(["Quantity", "Qty", "Size"]),
            EntryPrice = Guess(["Entry price", "Entry Price", "Buy Price", "Open Price"]),
            ExitPrice = Guess(["Exit price", "Exit Price", "Sell Price", "Close Price"]),
            OpenedAt = Guess(["Entry time", "Entry Time", "Open Time", "Opened At"]),
            ClosedAt = Guess(["Exit time", "Exit Time", "Close Time", "Closed At"]),
            GrossPnL = Guess(["Profit", "P/L", "PnL", "Net Profit", "Gross P&L"]),
            Commissions = GuessOptional(["Commission", "Commissions", "Fees"]),
            Tags = GuessOptional(["Tags", "Tag", "Setup"]),
            MaxAdverseExcursion = GuessOptional(["MAE", "Max Adverse Excursion", "Adverse Excursion"]),
            MaxFavorableExcursion = GuessOptional(["MFE", "Max Favorable Excursion", "Favorable Excursion"]),
        };
    }

    private RenderFragment ColumnOptions(bool includeNone = false) => builder =>
    {
        var seq = 0;
        if (includeNone)
        {
            builder.OpenElement(seq++, "option");
            builder.AddAttribute(seq++, "value", "");
            builder.AddContent(seq++, L["(ninguna)"]);
            builder.CloseElement();
        }
        foreach (var header in _genericCsvHeaders ?? [])
        {
            builder.OpenElement(seq++, "option");
            builder.AddAttribute(seq++, "value", header);
            builder.AddContent(seq++, header);
            builder.CloseElement();
        }
    };

