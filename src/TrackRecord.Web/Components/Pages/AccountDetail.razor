@page "/accounts/{AccountId:guid}"
@rendermode InteractiveServer
@implements IDisposable
@inject ITradingAccountService AccountService
@inject ITradeSetupService SetupService
@inject ICsvTradeImportService CsvImportService
@inject IGenericCsvImportService GenericCsvImportService
@inject CurrencyState Currency
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

<PageTitle>@(_account?.DisplayName ?? L["Cuenta"].Value) — @Brand.Name</PageTitle>

<ConfirmDialog @ref="_confirmDialog" />
<ImportTutorialModal @ref="_tutorialModal" />

@if (_account is null)
{
    <p><em>@L["Cargando…"]</em></p>
}
else
{
    <div class="d-flex justify-content-between align-items-start">
        <div>
            @if (_editingName)
            {
                <EditForm Model="_renameForm" OnValidSubmit="SaveNameAsync" class="mb-1">
                    <DataAnnotationsValidator />
                    <div class="d-flex gap-2 align-items-center">
                        <InputText class="form-control form-control-lg" style="max-width: 24rem;" @bind-Value="_renameForm.DisplayName" autofocus />
                        <button type="submit" class="btn btn-primary btn-sm">@L["Guardar"]</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CancelRename">@L["Cancelar"]</button>
                    </div>
                    <ValidationMessage For="() => _renameForm.DisplayName" class="text-danger small" />
                </EditForm>
                @if (_nameError is not null)
                {
                    <p class="text-danger small mb-0">@_nameError</p>
                }
            }
            else
            {
                <h1 class="d-flex align-items-center gap-2">
                    @_account.DisplayName
                    <button class="btn btn-sm btn-link p-0 text-muted" title="@L["Editar nombre"]" @onclick="StartRename">✏️</button>
                </h1>
            }
            <p class="text-muted mb-0">@_account.PropFirmName · @Currency.Format(_account.AccountSize, 0) · <span class="badge @StageBadgeClass(_account.Stage)">@_account.Stage</span></p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            @if (_account.EvaluationProgramId.HasValue)
            {
                <a class="btn btn-outline-primary btn-sm" href="/accounts/@AccountId/progress">📊 @L["Ver progreso"]</a>
            }
            <button class="btn btn-outline-danger" @onclick="ConfirmAndDeleteAccountAsync">@L["Eliminar cuenta"]</button>
        </div>
    </div>

    <div class="kpi-grid mt-3">
        <KpiCard Title="@L["Costes totales"]" Value="@Currency.Format(TotalCosts)" />
        <KpiCard Title="@L["Payouts recibidos"]" Value="@Currency.Format(TotalPayouts)" />
        <KpiCard Title="Profit target" Value="@Currency.Format(_account.ProfitTarget, 0)" />
        <KpiCard Title="Max drawdown" Value="@Currency.Format(_account.MaxDrawdown, 0)" />
    </div>

    <h2 class="mt-4">@L["Ciclo de vida"]</h2>
    <EditForm Model="_transition" OnValidSubmit="TransitionAsync" class="row g-2 align-items-end mb-2">
        <div class="col-md-3">
            <label class="form-label">@L["Nueva etapa"]</label>
            <InputSelect class="form-select" @bind-Value="_transition.NewStage">
                @foreach (var v in Enum.GetValues<AccountStage>())
                {
                    <option value="@v">@v</option>
                }
            </InputSelect>
        </div>
        <div class="col-md-3">
            <label class="form-label">@L["Fecha"]</label>
            <InputDate class="form-control" @bind-Value="_transition.OccurredOn" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@L["Notas"]</label>
            <InputText class="form-control" @bind-Value="_transition.Notes" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">@L["Registrar"]</button>
        </div>
    </EditForm>
    <ul class="list-group mb-4">
        @foreach (var evt in _account.Events)
        {
            <li class="list-group-item d-flex justify-content-between">
                <span>@evt.FromStage → <strong>@evt.ToStage</strong> @(string.IsNullOrWhiteSpace(evt.Notes) ? "" : $"— {evt.Notes}")</span>
                <span class="text-muted">@evt.OccurredAt.ToString("d")</span>
            </li>
        }
    </ul>

    <div class="row">
        <div class="col-md-6">
            <h2>@L["Costes"]</h2>
            <EditForm Model="_costForm" OnValidSubmit="AddCostAsync" class="row g-2 align-items-end mb-2">
                <div class="col-5">
                    <label class="form-label">@L["Tipo"]</label>
                    <InputSelect class="form-select" @bind-Value="_costForm.Kind">
                        @foreach (var v in Enum.GetValues<CostKind>())
                        {
                            <option value="@v">@v</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-3">
                    <label class="form-label">@L["Importe"]</label>
                    <InputNumber class="form-control" @bind-Value="_costForm.Amount" />
                </div>
                <div class="col-3">
                    <label class="form-label">@L["Fecha"]</label>
                    <InputDate class="form-control" @bind-Value="_costForm.PaidOn" />
                </div>
                <div class="col-1">
                    <button type="submit" class="btn btn-primary">+</button>
                </div>
            </EditForm>
            <ul class="list-group mb-4">
                @foreach (var cost in _account.Costs)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>@cost.Kind — @cost.PaidOn.ToString("d")</span>
                        <span>
                            @Currency.Format(cost.Amount)
                            <button class="btn btn-sm btn-link text-danger" @onclick="() => RemoveCostAsync(cost.Id)">✕</button>
                        </span>
                    </li>
                }
            </ul>
        </div>

        <div class="col-md-6">
            <h2>Payouts</h2>
            @if (_account.NextPayoutEligibleOn is { } nextPayoutOn)
            {
                var daysLeft = nextPayoutOn.DayNumber - DateOnly.FromDateTime(DateTime.Today).DayNumber;
                <div class="alert @(daysLeft <= 0 ? "alert-success" : "alert-secondary") small">
                    @if (daysLeft <= 0)
                    {
                        <text>@L["Ya puedes solicitar tu próximo payout según la regla de {0}.", _account.PropFirmName]</text>
                    }
                    else
                    {
                        <text>@L["Próximo payout elegible el {0} (en {1} día(s)), según la regla de {2}.", nextPayoutOn.ToString("d"), daysLeft, _account.PropFirmName]</text>
                    }
                </div>
            }
            <EditForm Model="_payoutForm" OnValidSubmit="AddPayoutAsync" class="row g-2 align-items-end mb-2">
                <div class="col-3">
                    <label class="form-label">@L["Solicitado"]</label>
                    <InputNumber class="form-control" @bind-Value="_payoutForm.AmountRequested" />
                </div>
                <div class="col-3">
                    <label class="form-label">@L["Recibido"]</label>
                    <InputNumber class="form-control" @bind-Value="_payoutForm.AmountReceived" />
                </div>
                <div class="col-3">
                    <label class="form-label">@L["Fecha solicitud"]</label>
                    <InputDate class="form-control" @bind-Value="_payoutForm.RequestedOn" />
                </div>
                <div class="col-2">
                    <label class="form-label">@L["Estado"]</label>
                    <InputSelect class="form-select" @bind-Value="_payoutForm.Status">
                        @foreach (var v in Enum.GetValues<PayoutStatus>())
                        {
                            <option value="@v">@v</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-1">
                    <button type="submit" class="btn btn-primary">+</button>
                </div>
            </EditForm>
            <ul class="list-group mb-4">
                @foreach (var payout in _account.Payouts)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>@payout.RequestedOn.ToString("d") — @payout.Status</span>
                        <span>
                            @Currency.Format(payout.AmountReceived)
                            <button class="btn btn-sm btn-link text-danger" @onclick="() => RemovePayoutAsync(payout.Id)">✕</button>
                        </span>
                    </li>
                }
            </ul>
        </div>
    </div>

    <h2 class="mt-4">@L["Journal de trades"]</h2>

    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-2">
                <h6 class="card-title">@L["Importar operaciones (CSV de Tradovate o NinjaTrader 8)"]</h6>
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="ShowTutorial">
                    📖 @L["¿Cómo exporto e importo mi CSV?"]
                </button>
            </div>
            <p class="text-muted small mb-2">
                @L["Sube el CSV exportado desde la app de Tradovate (Reports → Performance) o desde NinjaTrader 8 (Trade Performance → Trades → Export). El formato se detecta automáticamente y reimportar el mismo archivo no duplica trades."]
            </p>
            <div class="row g-2 align-items-end mb-2">
                <div class="col-md-3">
                    <label class="form-label small">@L["Plataforma de esta cuenta"]</label>
                    <InputSelect class="form-select form-select-sm" Value="_platform" ValueExpression="() => _platform" TValue="DataFeedType" ValueChanged="OnPlatformChangedAsync">
                        @foreach (var v in Enum.GetValues<DataFeedType>())
                        {
                            <option value="@v">@PlatformLabel(v)</option>
                        }
                    </InputSelect>
                </div>
            </div>
            <InputFile OnChange="OnCsvFileSelectedAsync" accept=".csv" disabled="@_csvImporting" />
            @if (_csvImporting)
            {
                <p class="text-muted small mt-2 mb-0"><em>@L["Importando…"]</em></p>
            }
            else if (_csvImportSummary is not null)
            {
                <p class="small mt-2 mb-0">
                    @L["Importados:"] <strong>@_csvImportSummary.Imported</strong> ·
                    @L["Omitidos (ya importados):"] <strong>@_csvImportSummary.Skipped</strong>
                    @if (_csvImportSummary.Errors.Count > 0)
                    {
                        <text> · <span class="text-danger">@L["{0} fila(s) con error", _csvImportSummary.Errors.Count]</span></text>
                    }
                </p>
                @if (_csvImportSummary.Errors.Count > 0)
                {
                    <ul class="small text-danger mb-0">
                        @foreach (var err in _csvImportSummary.Errors.Take(10))
                        {
                            <li>@err</li>
                        }
                    </ul>
                }
            }
        </div>
    </div>

    @* ── Import CSV universal con mapeo de columnas (GUIA_FUNCIONALIDADES_PROPUESTAS.md §4.6) ── *@
    <div class="card mb-3">
        <div class="card-body">
            <h6 class="card-title">@L["Importar CSV de otro broker (mapeo de columnas)"]</h6>
            <p class="text-muted small mb-2">
                @L["Para brokers sin soporte dedicado: sube el CSV, indica qué columna es cada campo y lo mapeamos nosotros. Reimportar el mismo archivo no duplica trades."]
            </p>
            <InputFile OnChange="OnGenericCsvFileSelectedAsync" accept=".csv" disabled="@_genericCsvImporting" />

            @if (_genericCsvHeaders is { Count: > 0 })
            {
                <div class="row g-2 mt-2">
                    <div class="col-md-3">
                        <label class="form-label small">@L["Símbolo"]</label>
                        <select class="form-select form-select-sm" @bind="_genericMapping.Symbol">@ColumnOptions()</select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">@L["Dirección (long/short)"]</label>
                        <select class="form-select form-select-sm" @bind="_genericMapping.Direction">@ColumnOptions()</select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">@L["Cantidad"]</label>
                        <select class="form-select form-select-sm" @bind="_genericMapping.Quantity">@ColumnOptions()</select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">@L["Precio entrada"]</label>
                        <select class="form-select form-select-sm" @bind="_genericMapping.EntryPrice">@ColumnOptions()</select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">@L["Precio salida"]</label>
                        <select class="form-select form-select-sm" @bind="_genericMapping.ExitPrice">@ColumnOptions()</select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">@L["Fecha/hora entrada"]</label>
                        <select class="form-select form-select-sm" @bind="_genericMapping.OpenedAt">@ColumnOptions()</select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">@L["Fecha/hora salida"]</label>
                        <select class="form-select form-select-sm" @bind="_genericMapping.ClosedAt">@ColumnOptions()</select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">@L["P&L bruto"]</label>
                        <select class="form-select form-select-sm" @bind="_genericMapping.GrossPnL">@ColumnOptions()</select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">@L["Comisiones (opcional)"]</label>
                        <select class="form-select form-select-sm" @bind="_genericMapping.Commissions">@ColumnOptions(includeNone: true)</select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Tags (@L["opcional"])</label>
                        <select class="form-select form-select-sm" @bind="_genericMapping.Tags">@ColumnOptions(includeNone: true)</select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">@L["Pérdida flotante máx. (opcional)"]</label>
                        <select class="form-select form-select-sm" @bind="_genericMapping.MaxAdverseExcursion">@ColumnOptions(includeNone: true)</select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">@L["Ganancia flotante máx. (opcional)"]</label>
                        <select class="form-select form-select-sm" @bind="_genericMapping.MaxFavorableExcursion">@ColumnOptions(includeNone: true)</select>
                    </div>
                </div>
                <button class="btn btn-sm btn-primary mt-2" disabled="@_genericCsvImporting" @onclick="ImportGenericCsvAsync">
                    @(_genericCsvImporting ? L["Importando…"] : L["Importar con este mapeo"])
                </button>
            }

            @if (_genericCsvError is not null)
            {
                <div class="alert alert-danger mt-2 mb-0 py-1 small">@_genericCsvError</div>
            }
            @if (_genericCsvSummary is not null)
            {
                <p class="small mt-2 mb-0">
                    @L["Importados:"] <strong>@_genericCsvSummary.Imported</strong> ·
                    @L["Omitidos (ya importados):"] <strong>@_genericCsvSummary.Skipped</strong>
                    @if (_genericCsvSummary.Errors.Count > 0)
                    {
                        <text> · <span class="text-danger">@L["{0} fila(s) con error", _genericCsvSummary.Errors.Count]</span></text>
                    }
                </p>
            }
        </div>
    </div>

    <EditForm Model="_tradeForm" OnValidSubmit="AddTradeAsync" class="row g-2 align-items-end mb-2">
        <div class="col-md-1">
            <label class="form-label">@L["Símbolo"]</label>
            <InputText class="form-control" @bind-Value="_tradeForm.Symbol" placeholder="MES" />
        </div>
        <div class="col-md-1">
            <label class="form-label">Dir.</label>
            <InputSelect class="form-select" @bind-Value="_tradeForm.Direction">
                @foreach (var v in Enum.GetValues<TradeDirection>())
                {
                    <option value="@v">@v</option>
                }
            </InputSelect>
        </div>
        <div class="col-md-1">
            <label class="form-label">@L["Cant."]</label>
            <InputNumber class="form-control" @bind-Value="_tradeForm.Quantity" />
        </div>
        <div class="col-md-2">
            <label class="form-label">@L["Fecha cierre"]</label>
            <InputDate class="form-control" @bind-Value="_tradeForm.ClosedOn" />
        </div>
        <div class="col-md-2">
            <label class="form-label">@L["P&L bruto"]</label>
            <InputNumber class="form-control" @bind-Value="_tradeForm.GrossPnL" />
        </div>
        <div class="col-md-2">
            <label class="form-label">@L["Comisiones"]</label>
            <InputNumber class="form-control" @bind-Value="_tradeForm.Commissions" />
        </div>
        <div class="col-md-2">
            <label class="form-label">@L["Riesgo (R)"]</label>
            <InputNumber class="form-control" @bind-Value="_tradeForm.RiskedAmount" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Tags (setup)</label>
            <InputText class="form-control" @bind-Value="_tradeForm.Tags" placeholder="breakout, news" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">@L["Pérdida flotante máx. (opcional)"]</label>
            <InputNumber class="form-control form-control-sm" @bind-Value="_tradeForm.MaxAdverseExcursion" placeholder="0" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">@L["Ganancia flotante máx. (opcional)"]</label>
            <InputNumber class="form-control form-control-sm" @bind-Value="_tradeForm.MaxFavorableExcursion" placeholder="0" />
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">+</button>
        </div>
    </EditForm>
    <p class="text-muted small mt-1 mb-2">
        @L["\"Pérdida/ganancia flotante máxima\": cuánto llegaste a estar en contra/a favor mientras el trade seguía abierto, antes de cerrarlo. Registrarlo habilita el análisis de MAE/MFE (calidad de ejecución)."]
    </p>

    @if (_account.Trades.Count == 0)
    {
        <p class="text-muted">@L["Sin trades registrados todavía."]</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>@L["Fecha"]</th>
                        <th>@L["Símbolo"]</th>
                        <th>Dir.</th>
                        <th>@L["Cant."]</th>
                        <th>@L["Setup"]</th>
                        <th class="text-end">@L["Riesgo"]</th>
                        <th class="text-end">R</th>
                        <th class="text-end">MAE</th>
                        <th class="text-end">MFE</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _account.Trades)
                    {
                        <tr>
                            <td>@t.ClosedAt.ToString("d")</td>
                            <td>@t.Symbol</td>
                            <td>@t.Direction</td>
                            <td>@t.Quantity</td>
                            <td>
                                <select class="form-select form-select-sm" style="min-width:9rem"
                                        @onchange="@(e => UpdateTradeSetupAsync(t, e.Value?.ToString()))">
                                    <option value="" selected="@string.IsNullOrEmpty(t.Tags)">—</option>
                                    @foreach (var s in _setups ?? [])
                                    {
                                        <option value="@s.Name" selected="@(s.Name == t.Tags)">@s.Name</option>
                                    }
                                    @if (!string.IsNullOrEmpty(t.Tags) && _setups?.Any(s => s.Name == t.Tags) != true)
                                    {
                                        <option value="@t.Tags" selected>@t.Tags</option>
                                    }
                                </select>
                            </td>
                            <td class="text-end" style="width:100px">
                                <input type="number" step="0.01" class="form-control form-control-sm text-end" value="@t.RiskedAmount"
                                       @onchange="@(e => UpdateTradeRiskAsync(t, decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : (decimal?)null))" />
                            </td>
                            <td class="text-end">@(t.RMultiple?.ToString("0.00") ?? "—")</td>
                            <td class="text-end text-danger">
                                @(t.MaxAdverseExcursion is { } mae ? Currency.Format(-mae) : "—")
                                @if (t.MaeR is { } maeR)
                                {
                                    <small class="text-muted">(@maeR.ToString("0.00")R)</small>
                                }
                            </td>
                            <td class="text-end text-success">
                                @(t.MaxFavorableExcursion is { } mfe ? Currency.Format(mfe) : "—")
                                @if (t.MfeR is { } mfeR)
                                {
                                    <small class="text-muted">(@mfeR.ToString("0.00")R)</small>
                                }
                            </td>
                            <td><button class="btn btn-sm btn-link text-danger" @onclick="() => DeleteTradeAsync(t.Id)">✕</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    [Parameter] public Guid AccountId { get; set; }

    private TradingAccountDetailDto? _account;
    private ConfirmDialog? _confirmDialog;

    private decimal TotalCosts => _account?.Costs.Sum(c => c.Amount) ?? 0m;
    private decimal TotalPayouts => _account?.Payouts.Sum(p => p.AmountReceived) ?? 0m;

    private TransitionFormModel _transition = new();
    private CostFormModel _costForm = new();
    private PayoutFormModel _payoutForm = new();
    private TradeFormModel _tradeForm = new();
    private DataFeedType _platform = DataFeedType.Manual;
    private ImportTutorialModal? _tutorialModal;

    private bool _editingName;
    private RenameFormModel _renameForm = new();
    private string? _nameError;

    private bool _csvImporting;
    private CsvImportSummary? _csvImportSummary;

    private MemoryStream? _genericCsvBuffer;
    private IReadOnlyList<string>? _genericCsvHeaders;
    private GenericCsvMappingFormModel _genericMapping = new();
    private bool _genericCsvImporting;
    private string? _genericCsvError;
    private CsvImportSummary? _genericCsvSummary;

    private List<TradeSetupDto>? _setups;

    protected override async Task OnInitializedAsync()
    {
        Currency.Changed += OnCurrencyChanged;
        _setups = (await SetupService.GetAllAsync()).ToList();
        await LoadAsync();
    }

    private void OnCurrencyChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Currency.Changed -= OnCurrencyChanged;
        _genericCsvBuffer?.Dispose();
    }

    private async Task LoadAsync()
    {
        _account = await AccountService.GetByIdAsync(AccountId);
        if (_account is null)
        {
            Nav.NavigateTo("/accounts");
            return;
        }

        _platform = _account.Feed;
    }

    private void StartRename()
    {
        _nameError = null;
        _renameForm = new RenameFormModel { DisplayName = _account?.DisplayName ?? "" };
        _editingName = true;
    }

    private void CancelRename()
    {
        _editingName = false;
        _nameError = null;
    }

    private async Task SaveNameAsync()
    {
        if (_account is null) return;
        _nameError = null;
        try
        {
            await AccountService.RenameAsync(new RenameAccountRequest(AccountId, _renameForm.DisplayName));
            _editingName = false;
            await LoadAsync();
        }
        catch (ArgumentException ex)
        {
            _nameError = ex.Message;
        }
    }

    /// <summary>Guarda la plataforma de la cuenta al cambiarla; solo condiciona la pestaña inicial del tutorial.</summary>
    private async Task OnPlatformChangedAsync(DataFeedType platform)
    {
        _platform = platform;
        await AccountService.UpdateConnectionAsync(new UpdateAccountConnectionRequest(
            AccountId, platform, _account?.ExternalAccountId));
    }

    private void ShowTutorial() => _tutorialModal?.Show(_platform);

    private static string PlatformLabel(DataFeedType feed) => feed switch
    {
        DataFeedType.Tradovate => "Tradovate",
        DataFeedType.NinjaTrader => "NinjaTrader 8",
        _ => "Manual / otra",
    };

    private async Task TransitionAsync()
    {
        await AccountService.TransitionStageAsync(new TransitionAccountStageRequest(
            AccountId, _transition.NewStage, _transition.OccurredOn.ToDateTime(TimeOnly.MinValue), _transition.Notes));
        _transition = new TransitionFormModel();
        await LoadAsync();
    }

    private async Task AddCostAsync()
    {
        await AccountService.AddCostAsync(new AddAccountCostRequest(AccountId, _costForm.Kind, _costForm.Amount, _costForm.PaidOn, null));
        _costForm = new CostFormModel();
        await LoadAsync();
    }

    private async Task RemoveCostAsync(Guid costId)
    {
        await AccountService.RemoveCostAsync(costId);
        await LoadAsync();
    }

    private async Task AddPayoutAsync()
    {
        await AccountService.AddPayoutAsync(new AddPayoutRequest(
            AccountId, _payoutForm.AmountRequested, _payoutForm.AmountReceived, _payoutForm.RequestedOn,
            _payoutForm.Status == PayoutStatus.Paid ? _payoutForm.RequestedOn : null, _payoutForm.Status, null));
        _payoutForm = new PayoutFormModel();
        await LoadAsync();
    }

    private async Task RemovePayoutAsync(Guid payoutId)
    {
        await AccountService.RemovePayoutAsync(payoutId);
        await LoadAsync();
    }

    private async Task AddTradeAsync()
    {
        var closedAt = _tradeForm.ClosedOn.ToDateTime(TimeOnly.MinValue);
        await AccountService.AddTradeAsync(new CreateTradeRequest(
            AccountId, _tradeForm.Symbol, _tradeForm.Direction, _tradeForm.Quantity,
            0m, 0m, closedAt, closedAt, _tradeForm.GrossPnL, _tradeForm.Commissions,
            _tradeForm.RiskedAmount, string.IsNullOrWhiteSpace(_tradeForm.Tags) ? null : _tradeForm.Tags, null,
            _tradeForm.MaxAdverseExcursion, _tradeForm.MaxFavorableExcursion));
        _tradeForm = new TradeFormModel();
        await LoadAsync();
    }

    private static string[] ParseTags(string? tags) =>
        tags?.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries) ?? [];

    /// <summary>Asigna el setup elegido en el desplegable como Tags del trade — pensado para completar trades importados de CSV, que llegan sin esta información.</summary>
    private async Task UpdateTradeSetupAsync(TradeListItemDto trade, string? setupName)
    {
        await AccountService.UpdateTradeSetupTagAsync(new UpdateTradeSetupTagRequest(
            trade.Id, string.IsNullOrEmpty(setupName) ? null : setupName, trade.RiskedAmount));
        await LoadAsync();
    }

    /// <summary>Guarda el riesgo asumido en el trade — habilita R-múltiplo, MAE-en-R y MFE-en-R, que CSV no puede reportar por sí solo.</summary>
    private async Task UpdateTradeRiskAsync(TradeListItemDto trade, decimal? riskedAmount)
    {
        await AccountService.UpdateTradeSetupTagAsync(new UpdateTradeSetupTagRequest(trade.Id, trade.Tags, riskedAmount));
        await LoadAsync();
    }

    private async Task DeleteTradeAsync(Guid tradeId)
    {
