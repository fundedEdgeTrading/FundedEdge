@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResources> L

<div class="public-shell">
    <header class="public-header">
        <a class="public-brand" href="bienvenida" aria-label="@($"{Brand.Name} — inicio")">
            <span class="brand-mark">
                <span class="brand-mark-glass"></span>
                <span class="brand-mark-sheen"></span>
                <svg class="brand-logo" viewBox="0 0 28 28" aria-hidden="true">
                    <defs>
                        <linearGradient id="logoInkPublic" x1="0" y1="1" x2="0" y2="0">
                            <stop offset="0%" stop-color="#04241b" />
                            <stop offset="100%" stop-color="#0a3d2d" />
                        </linearGradient>
                    </defs>
                    <rect class="logo-bar" x="4.5" y="15" width="3.6" height="8.5" rx="1.1" fill="url(#logoInkPublic)" opacity="0.88" />
                    <rect class="logo-bar" x="12.2" y="10.2" width="3.6" height="13.3" rx="1.1" fill="url(#logoInkPublic)" opacity="0.94" />
                    <rect class="logo-bar" x="19.9" y="5.6" width="3.6" height="17.9" rx="1.1" fill="url(#logoInkPublic)" />
                    <path class="logo-line" d="M4 12.5 L11 7.6 L16.3 10.9 L24.3 3.4" pathLength="1" fill="none" stroke="#06281f" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" />
                    <path class="logo-tip" d="M18.6 3.1 L24.3 3.4 L24.6 9.1" pathLength="1" fill="none" stroke="#06281f" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </span>
            <span class="brand-text">
                <span class="brand-name">Funded<span class="brand-edge">Edge</span></span>
                <span class="brand-sub"><span class="brand-sub-tick"></span>Trading Intelligence</span>
            </span>
        </a>
        <nav class="public-nav">
            <a href="bienvenida#features">@L["Producto"]</a>
            <a href="bienvenida#como-funciona">@L["Cómo funciona"]</a>
            <a href="bienvenida#precios">@L["Precios"]</a>
            <a href="calculadora">@L["Calculadora"]</a>
            <a href="Account/Login">@L["Iniciar sesión"]</a>
            <a class="btn btn-primary btn-sm" href="Account/Register">@L["Crear cuenta"]</a>
            <CultureSelector />
        </nav>
    </header>

    <main class="public-main">
        @Body
    </main>

    <footer class="public-footer">
        <span>© @DateTime.UtcNow.Year @Brand.Name · @L[Brand.Tagline]</span>
    </footer>
</div>
