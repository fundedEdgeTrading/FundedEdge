@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using TrackRecord.Infrastructure.Identity

@inject SignInManager<ApplicationUser> SignInManager
@inject IStringLocalizer<SharedResources> L

@if (externalLogins.Length > 0)
{
    <form class="d-flex flex-column gap-2" action="Account/PerformExternalLogin" method="post">
        <AntiforgeryToken />
        <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
        @foreach (var provider in externalLogins)
        {
            <button type="submit" class="btn btn-outline-secondary w-100" name="provider" value="@provider.Name"
                    title="@L["Continuar con {0}", provider.DisplayName ?? provider.Name]">
                @if (provider.Name == "Google")
                {
                    <svg width="16" height="16" viewBox="0 0 48 48" class="me-2" aria-hidden="true">
                        <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.9 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 8 3l6-6C34 5.4 29.3 3.5 24 3.5 12.7 3.5 3.5 12.7 3.5 24S12.7 44.5 24 44.5 44.5 35.3 44.5 24c0-1.2-.1-2.4-.4-3.5z" />
                        <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.6 15.9 18.9 13 24 13c3.1 0 5.8 1.1 8 3l6-6C34 5.4 29.3 3.5 24 3.5c-7.6 0-14.1 4.3-17.7 11.2z" />
                        <path fill="#4CAF50" d="M24 44.5c5.2 0 9.9-1.8 13.5-4.9l-6.2-5.3c-2 1.4-4.6 2.2-7.3 2.2-5.3 0-9.7-3.1-11.3-7.6l-6.5 5c3.6 6.9 10.1 10.6 17.8 10.6z" />
                        <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4.2 5.6l6.2 5.3C39.9 36.9 44.5 31 44.5 24c0-1.2-.1-2.4-.4-3.5z" />
                    </svg>
                }
                @L["Continuar con {0}", provider.DisplayName ?? provider.Name]
            </button>
        }
    </form>
}

@code {
    private AuthenticationScheme[] externalLogins = [];

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        externalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToArray();
    }
}
