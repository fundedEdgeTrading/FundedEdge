@page "/Account/ForgotPassword"

@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using TrackRecord.Infrastructure.Email
@using TrackRecord.Infrastructure.Identity

@inject UserManager<ApplicationUser> UserManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject EmailOptions EmailOptions
@inject IdentityRedirectManager RedirectManager
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["¿Has olvidado tu contraseña?"] — @Brand.Name</PageTitle>

<div class="auth-shell">
    <AuthCard Title="@L["¿Has olvidado tu contraseña?"]">
        <Subtitle>@L["Escribe tu email y te enviaremos un enlace para restablecerla."]</Subtitle>

        <ChildContent>
            @if (devResetLink is not null)
            {
                @* Sin SMTP configurado (solo desarrollo) el enlace se enseña aquí para poder completar el flujo. *@
                <div class="alert alert-warning text-start">
                    @L["El envío de emails no está configurado (Email:SmtpHost / Email:From), así que el enlace de restablecimiento se muestra aquí. En producción, configura SMTP — ver README."]
                </div>
                <p><a class="btn btn-primary" href="@devResetLink">@L["Restablecer mi contraseña"]</a></p>
            }
            else
            {
                <EditForm Model="Input" method="post" OnValidSubmit="OnValidSubmitAsync" FormName="forgot-password">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger" role="alert" />
                    <div class="mb-3 auth-field">
                        <label for="Input.Email" class="form-label">Email</label>
                        <InputText @bind-Value="Input.Email" id="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="tu@email.com" />
                        <ValidationMessage For="() => Input.Email" class="text-danger" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">@L["Enviar enlace de restablecimiento"]</button>
                </EditForm>

                <p class="auth-footer">
                    <a href="Account/Login">@L["Volver a iniciar sesión"]</a>
                </p>
            }
        </ChildContent>
    </AuthCard>
</div>

@code {
    private string? devResetLink;

    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null || !await UserManager.IsEmailConfirmedAsync(user))
        {
            // No revelar si el email existe o no: siempre se muestra la misma confirmación.
            RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
            return;
        }

        var code = await UserManager.GeneratePasswordResetTokenAsync(user);
        code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
        var callbackUrl = NavigationManager.GetUriWithQueryParameters(
            NavigationManager.ToAbsoluteUri("Account/ResetPassword").AbsoluteUri,
            new Dictionary<string, object?> { ["code"] = code });

        if (EmailOptions.IsConfigured)
        {
            await EmailSender.SendPasswordResetLinkAsync(user, Input.Email, HtmlEncoder.Default.Encode(callbackUrl));
            RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
        }
        else
        {
            devResetLink = callbackUrl;
        }
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        [Display(Name = "Email")]
        public string Email { get; set; } = "";
    }
}
