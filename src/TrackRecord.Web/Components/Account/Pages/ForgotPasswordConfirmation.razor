@page "/Account/ForgotPasswordConfirmation"

@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Revisa tu email"] — @Brand.Name</PageTitle>

<div class="auth-shell">
    <AuthCard Title="@L["Revisa tu email"]" Centered="true">
        <ChildContent>
            <p class="text-muted">@L["Si existe una cuenta con ese email, te hemos enviado un enlace para restablecer la contraseña. Revisa tu bandeja de entrada (y la carpeta de spam)."]</p>
            <p class="auth-footer">
                <a href="Account/Login">@L["Volver a iniciar sesión"]</a>
            </p>
        </ChildContent>
    </AuthCard>
</div>
