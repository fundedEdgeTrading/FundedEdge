@page "/Account/ResetPassword"

@using System.ComponentModel.DataAnnotations
@using System.Text
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using TrackRecord.Infrastructure.Identity

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Restablecer contraseña"] — @Brand.Name</PageTitle>

<div class="auth-shell">
    <AuthCard Title="@L["Restablecer contraseña"]">
        <Subtitle>@L["Elige una contraseña nueva para tu cuenta."]</Subtitle>

        <ChildContent>
            <StatusMessage Message="@errorMessage" />

            <EditForm Model="Input" method="post" OnValidSubmit="OnValidSubmitAsync" FormName="reset-password">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert" />

                <input type="hidden" name="Input.Code" value="@Input.Code" />
                <div class="mb-3 auth-field">
                    <label for="Input.Email" class="form-label">Email</label>
                    <InputText @bind-Value="Input.Email" id="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="tu@email.com" />
                    <ValidationMessage For="() => Input.Email" class="text-danger" />
                </div>
                <div class="mb-3 auth-field">
                    <label for="Input.Password" class="form-label">@L["Contraseña nueva"]</label>
                    <InputText type="password" @bind-Value="Input.Password" id="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="@L["Mínimo 10 caracteres"]" />
                    <ValidationMessage For="() => Input.Password" class="text-danger" />
                </div>
                <div class="mb-3 auth-field">
                    <label for="Input.ConfirmPassword" class="form-label">@L["Confirmar contraseña"]</label>
                    <InputText type="password" @bind-Value="Input.ConfirmPassword" id="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                    <ValidationMessage For="() => Input.ConfirmPassword" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary w-100">@L["Restablecer contraseña"]</button>
            </EditForm>
        </ChildContent>
    </AuthCard>
</div>

@code {
    private string? errorMessage;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    protected override void OnInitialized()
    {
        if (Input.Code is null)
        {
            if (Code is null)
            {
                RedirectManager.RedirectTo("Account/ForgotPassword");
                return;
            }

            Input.Code = Code;
        }
    }

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null)
        {
            // No revelar si el email existe: se muestra la misma confirmación.
            RedirectManager.RedirectTo("Account/ResetPasswordConfirmation");
            return;
        }

        IdentityResult result;
        try
        {
            var code = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Input.Code!));
            result = await UserManager.ResetPasswordAsync(user, code, Input.Password);
        }
        catch (FormatException)
        {
            result = IdentityResult.Failed(UserManager.ErrorDescriber.InvalidToken());
        }

        if (result.Succeeded)
        {
            RedirectManager.RedirectTo("Account/ResetPasswordConfirmation");
            return;
        }

        errorMessage = $"Error: {string.Join(" ", result.Errors.Select(e => e.Description))}";
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        [Display(Name = "Email")]
        public string Email { get; set; } = "";

        [Required]
        [StringLength(100, ErrorMessage = "La {0} debe tener entre {2} y {1} caracteres.", MinimumLength = 10)]
        [DataType(DataType.Password)]
        [Display(Name = "Contraseña")]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Display(Name = "Confirmar contraseña")]
        [Compare("Password", ErrorMessage = "La contraseña y su confirmación no coinciden.")]
        public string ConfirmPassword { get; set; } = "";

        [Required]
        public string? Code { get; set; }
    }
}
