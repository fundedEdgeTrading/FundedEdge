@page "/Account/ResetPasswordConfirmation"

@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Contraseña restablecida"] — @Brand.Name</PageTitle>

<div class="auth-shell">
    <AuthCard Title="@L["Contraseña restablecida"]" Centered="true">
        <ChildContent>
            <p class="text-muted">@L["Tu contraseña se ha restablecido correctamente. Ya puedes iniciar sesión con la nueva."]</p>
            <p><a class="btn btn-primary" href="Account/Login">@L["Iniciar sesión"]</a></p>
        </ChildContent>
    </AuthCard>
</div>
