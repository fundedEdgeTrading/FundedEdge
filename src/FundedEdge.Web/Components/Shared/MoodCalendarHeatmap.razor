@* Calendario emocional: un cuadrado por día, coloreado por valencia media (rojo=negativa, verde=positiva). *@
@inject IStringLocalizer<SharedResources> L

@if (Days.Count == 0)
{
    <EmptyState Title="@L["Sin datos suficientes"]" Text="@L["Registra check-ins diarios y emociones de trades para ver el calendario emocional."]" />
}
else
{
    <div class="mood-calendar">
        @foreach (var day in Days)
        {
            <div class="mood-calendar-cell" style="background:@ColorFor(day.AvgValence)" title="@Tooltip(day)"></div>
        }
    </div>
    <p class="small text-muted mt-2 mb-0">@L["Cada cuadrado es un día de operativa; el color refleja la valencia emocional media (verde = positiva, rojo = negativa)."]</p>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<FundedEdge.Application.Dtos.MoodCalendarDay> Days { get; set; } = [];

    private static string ColorFor(double valence)
    {
        // valence en [-1, 1]; interpolación simple hacia verde/rojo con opacidad por intensidad.
        var intensity = Math.Clamp(Math.Abs(valence), 0.1, 1.0);
        return valence >= 0
            ? $"rgba(63, 185, 80, {intensity:0.00})"
            : $"rgba(248, 81, 73, {intensity:0.00})";
    }

    private static string Tooltip(FundedEdge.Application.Dtos.MoodCalendarDay day) =>
        $"{day.Date:d MMM}: valencia {day.AvgValence:0.00}, PnL {day.NetPnL:0.##}";
}
