@* "Equity curve emocional": media móvil (7 días) de la valencia diaria. Cuando cae mientras el
   PnL sube, es una señal de alerta — se anota como texto bajo la gráfica, no en la propia curva. *@
@inject IStringLocalizer<SharedResources> L

@if (Points.Count == 0)
{
    <EmptyState Title="@L["Sin datos suficientes"]" Text="@L["Registra tu diario emocional para ver la evolución de tu capital emocional."]" />
}
else
{
    <svg class="chart-svg" viewBox="0 0 @W @H" preserveAspectRatio="xMidYMid meet" role="img"
         aria-label="@L["Capital emocional: media móvil de valencia diaria"]">
        <line class="chart-gridline chart-zero" x1="@PadL" x2="@(W - PadR)" y1="@F(Y(0))" y2="@F(Y(0))" />
        @SvgText("chart-tick", PadL - 7, Y(1) + 3.5, "end", "+")
        @SvgText("chart-tick", PadL - 7, Y(-1) + 3.5, "end", "−")

        <polyline class="chart-line" pathLength="1" points="@_linePoints" />
        <circle class="chart-line-dot" cx="@F(X(Points.Count - 1))" cy="@F(Y(Points[^1].Valence))" r="3.5" />
    </svg>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<FundedEdge.Domain.Psychology.EmotionalCapitalPoint> Points { get; set; } = [];

    private const int W = 720, H = 160, PadL = 24, PadR = 16, PadT = 14, PadB = 14;
    private string _linePoints = "";

    protected override void OnParametersSet()
    {
        if (Points.Count == 0) return;
        _linePoints = string.Join(" ", Enumerable.Range(0, Points.Count)
            .Select(i => $"{F(X(i))},{F(Y(Points[i].Valence))}"));
    }

    private double X(int i) => Points.Count <= 1
        ? (PadL + W - PadR) / 2.0
        : PadL + (double)i / (Points.Count - 1) * (W - PadL - PadR);

    private double Y(double value) =>
        PadT + (1 - Math.Clamp(value, -1, 1)) / 2 * (H - PadT - PadB);

    private static string F(double v) => v.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private static MarkupString SvgText(string cls, double x, double y, string anchor, string content) =>
        new($"<text class=\"{cls}\" x=\"{F(x)}\" y=\"{F(y)}\" text-anchor=\"{anchor}\">{System.Net.WebUtility.HtmlEncode(content)}</text>");
}
