@* Selector de emociones por chips (fricción mínima, sin texto obligatorio) con intensidad 1-5
   para cada emoción seleccionada. GUIA_PSICOLOGIA_TRADING.md §1.2/§5. *@
@using FundedEdge.Domain.Enums
@using FundedEdge.Web.Support

<div class="emotion-chip-group">
    @foreach (var emotion in EmotionDisplay.All)
    {
        var isSelected = Selected.ContainsKey(emotion);
        <button type="button" class="btn btn-sm @(isSelected ? "btn-primary" : "btn-outline-secondary")"
                disabled="@(!isSelected && Selected.Count >= MaxSelections)"
                @onclick="() => Toggle(emotion)">
            @EmotionDisplay.Emoji(emotion) @EmotionDisplay.Label(emotion)
        </button>
    }
</div>

@if (Selected.Count > 0)
{
    <div class="mt-2">
        @foreach (var emotion in Selected.Keys.ToList())
        {
            <div class="d-flex align-items-center gap-2 small mb-1">
                <span style="min-width:8rem">@EmotionDisplay.Emoji(emotion) @EmotionDisplay.Label(emotion)</span>
                <input type="range" min="1" max="5" class="form-range" style="max-width:10rem"
                       value="@Selected[emotion]"
                       @oninput="e => SetIntensity(emotion, int.Parse((string)e.Value!))" />
                <span>@Selected[emotion]/5</span>
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public Dictionary<EmotionType, int> Selected { get; set; } = new();
    [Parameter] public int MaxSelections { get; set; } = 3;
    [Parameter] public EventCallback OnChanged { get; set; }

    private async Task Toggle(EmotionType emotion)
    {
        if (Selected.ContainsKey(emotion))
        {
            Selected.Remove(emotion);
        }
        else
        {
            if (Selected.Count >= MaxSelections) return;
            Selected[emotion] = 3;
        }
        await OnChanged.InvokeAsync();
    }

    private async Task SetIntensity(EmotionType emotion, int intensity)
    {
        Selected[emotion] = Math.Clamp(intensity, 1, 5);
        await OnChanged.InvokeAsync();
    }
}
