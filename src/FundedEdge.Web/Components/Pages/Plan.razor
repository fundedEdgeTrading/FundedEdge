@page "/plan"
@rendermode InteractiveServer
@using FundedEdge.Infrastructure.Billing
@inject IPlanService PlanService
@inject ITradingAccountService AccountService
@inject IPublicProfileService PublicProfileService
@inject BillingOptions Billing
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Tu plan"] — @Brand.Name</PageTitle>

<h1>@L["Tu plan"]</h1>
<p class="text-muted">@L["Límites de cuentas, sincronización automática y uso de IA de tu suscripción."]</p>

@if (_tier is null)
{
    <div class="card" aria-label="@L["Cargando…"]">
        <div class="card-body">
            <div class="skeleton skeleton-label mb-2" style="width:35%"></div>
            <div class="skeleton skeleton-label" style="width:75%"></div>
        </div>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">@L["Plan actual:"] <span class="stage stage-accent">@_tier</span></h5>
            </div>
            <p class="small text-muted mt-2 mb-0">
                @L["Cuentas activas:"] @_activeAccounts / @(_limits!.MaxActiveAccounts?.ToString() ?? "∞") ·
                @L["Informes IA: {0} cada {1} día(s)", _limits.AiReportsPerWindow, _limits.AiReportWindowDays] ·
                @L["Preguntas IA/mes:"] @(_limits.AiQuestionsPerMonth?.ToString() ?? L["ilimitadas"].Value)
            </p>
        </div>
    </div>

    @if (!Billing.IsConfigured)
    {
        <div class="alert alert-secondary">@L["Pagos no configurados todavía — puedes seguir usando tu plan actual sin límite de tiempo."]</div>
    }

    <div class="currency-toggle mb-3" role="group" aria-label="@L["Periodo de facturación"]">
        <button type="button" class="currency-option @(!_yearly ? "active" : "")" @onclick="() => _yearly = false">
            @L["Mensual"]
        </button>
        <button type="button" class="currency-option @(_yearly ? "active" : "")" @onclick="() => _yearly = true">
            @L["Anual"] <span class="badge text-bg-success ms-1">-17%</span>
        </button>
    </div>

    <div class="row g-3">
        @foreach (var plan in PlanCatalog)
        {
            <div class="col-md-4">
                <div class="card h-100 plan-card @(plan.Tier == _tier ? "plan-current" : "")">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">@plan.Tier</h5>
                            @if (plan.Tier == _tier)
                            {
                                <span class="stage stage-accent">@L["Tu plan actual"]</span>
                            }
                        </div>
                        <p class="plan-price">@PriceLabel(plan)</p>
                        @if (_yearly && plan.MonthlyPrice is not null)
                        {
                            <p class="text-muted small mb-0">@L["equivale a {0}", MonthlyEquivalent(plan)]</p>
                        }
                        <ul class="plan-features flex-grow-1">
                            @foreach (var feature in plan.Features)
                            {
                                <li>@L[feature]</li>
                            }
                        </ul>
                        @if (plan.Tier == _tier)
                        {
                            <button class="btn btn-outline-secondary w-100" disabled>@L["Tu plan actual"]</button>
                        }
                        else if (plan.Tier == PlanTier.Starter)
                        {
                            <button class="btn btn-outline-secondary w-100" disabled title="@L["Cancela tu suscripción para volver a Starter"]">@L["Plan gratuito"]</button>
                        }
                        else
                        {
                            <form action="api/billing/checkout" method="post">
                                <AntiforgeryToken />
                                <input type="hidden" name="tier" value="@plan.Tier" />
                                <input type="hidden" name="yearly" value="@(_yearly ? "true" : "false")" />
                                <button type="submit" class="btn btn-primary w-100" disabled="@(!Billing.IsConfigured)">
                                    @L["Empezar con {0}", plan.Tier]
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (_tier is PlanTier.Pro or PlanTier.Elite)
    {
        <form action="api/billing/portal" method="post" class="mt-3">
            <AntiforgeryToken />
            <button type="submit" class="btn btn-outline-secondary btn-sm" disabled="@(!Billing.IsConfigured)">
                @L["Gestionar suscripción / cancelar"]
            </button>
        </form>
    }

    @if (_profile is not null)
    {
        <div class="card mt-4">
            <div class="card-body">
                <h5 class="card-title">@L["Track record público"]</h5>
                @if (!_profile.CanPublish)
                {
                    <p class="text-muted small mb-0">@L["Disponible en el plan Elite — comparte tus KPIs agregados (sin importes ni trades) en una página pública."]</p>
                }
                else if (_profile.IsEnabled)
                {
                    <p class="small mb-2">
                        @L["Tu página está activa en"] <a href="@($"t/{_profile.Slug}")" target="_blank">@($"{Nav.BaseUri}t/{_profile.Slug}")</a>
                    </p>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="DisableAsync">@L["Desactivar"]</button>

                    <hr />
                    <h6 class="mb-1">@L["Perfiles Elite"]</h6>
                    <p class="text-muted small mb-2">@L["Permite que otros usuarios Elite analicen tu operativa e IA genere informes de inspiración. Solo agregados — nunca tus trades ni importes."]</p>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="shareOperativa" checked="@_profile.ShareOperativa" @onchange="OnShareOperativaChanged" />
                        <label class="form-check-label small" for="shareOperativa">@L["Compartir mi operativa (setups, franjas, R-múltiplos)"]</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="shareEmotions" checked="@_profile.ShareEmotions" disabled="@(!_profile.ShareOperativa)" @onchange="OnShareEmotionsChanged" />
                        <label class="form-check-label small" for="shareEmotions">@L["Incluir también mi patrón emocional agregado"]</label>
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-2">@L["Actívala para compartir tu pass rate, win rate y profit factor con un enlace público."]</p>
                    <button class="btn btn-primary btn-sm" @onclick="EnableAsync">@L["Activar página pública"]</button>
                }
            </div>
        </div>
    }
}

@code {
    private PlanTier? _tier;
    private PlanLimits? _limits;
    private int _activeAccounts;

    // Precios anuales = 149 €/299 € (GUIA_MONETIZACION_Y_MARKETING.md §3): ~17 % de descuento
    // frente a 12 mensualidades, coherente con los Price Id de Stripe (Stripe:Prices:*Yearly).
    private static readonly (PlanTier Tier, decimal? MonthlyPrice, decimal? YearlyPrice, string[] Features)[] PlanCatalog =
    [
        (PlanTier.Starter, null, null, ["2 cuentas activas", "Dashboard de KPIs de negocio y trading", "Diario de trades y diario emocional", "Firm Fit: tu mejor programa", "1 informe IA al mes · 3 preguntas IA al mes"]),
        (PlanTier.Pro, 14.99m, 149m, ["10 cuentas activas", "Sincronización automática (Tradovate / NinjaTrader)", "Firm Fit completo: ranking, sensibilidad a reglas y plan de compra", "Módulo de riesgo completo (Monte Carlo, EV, Kelly)", "Alertas de drawdown", "Informe IA semanal automático · 30 preguntas IA al mes", "Export PDF del track record"]),
        (PlanTier.Elite, 29.99m, 299m, ["Cuentas activas ilimitadas · todo lo de Pro", "IA con el modelo más avanzado (Opus): análisis mucho más profundo", "1 informe IA al día · preguntas IA ilimitadas", "Track record público verificado", "Perfiles Elite: benchmarking e inspiración IA de los mejores"]),
    ];

    private bool _yearly;
    private PublicProfileSettings? _profile;

    private string PriceLabel((PlanTier Tier, decimal? MonthlyPrice, decimal? YearlyPrice, string[] Features) plan) =>
        plan.MonthlyPrice is null
            ? L["Gratis"].Value
            : _yearly ? $"{plan.YearlyPrice:0.##} €/{L["año"]}" : $"{plan.MonthlyPrice:0.##} €/{L["mes"]}";

    private string MonthlyEquivalent((PlanTier Tier, decimal? MonthlyPrice, decimal? YearlyPrice, string[] Features) plan) =>
        $"{plan.YearlyPrice / 12:0.##} €/{L["mes"]}";

    protected override async Task OnInitializedAsync()
    {
        _tier = await PlanService.GetTierAsync();
        _limits = await PlanService.GetLimitsAsync();

        var accounts = await AccountService.GetAllAsync();
        _activeAccounts = accounts.Count(a => a.Stage is AccountStage.Evaluation or AccountStage.Funded);

        _profile = await PublicProfileService.GetOwnSettingsAsync();
    }

    private async Task EnableAsync()
    {
        _profile = await PublicProfileService.EnableAsync();
    }

    private async Task DisableAsync()
    {
        await PublicProfileService.DisableAsync();
        _profile = await PublicProfileService.GetOwnSettingsAsync();
    }

    private async Task OnShareOperativaChanged(ChangeEventArgs e)
    {
        var share = (bool)(e.Value ?? false);
        _profile = await PublicProfileService.UpdateSharingAsync(share, share && (_profile?.ShareEmotions ?? false));
    }

    private async Task OnShareEmotionsChanged(ChangeEventArgs e)
    {
        var share = (bool)(e.Value ?? false);
        _profile = await PublicProfileService.UpdateSharingAsync(_profile?.ShareOperativa ?? false, share);
    }
}
