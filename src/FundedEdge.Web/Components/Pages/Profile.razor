@page "/settings/profile"

@using System.ComponentModel.DataAnnotations
@using System.IO
@using System.Text
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Hosting
@using Microsoft.AspNetCore.Http
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using FundedEdge.Web.Components.Account
@using FundedEdge.Web.Components.Account.Shared
@using FundedEdge.Infrastructure.Email
@using FundedEdge.Infrastructure.Identity

@attribute [ExcludeFromInteractiveRouting]

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject EmailOptions EmailOptions
@inject IWebHostEnvironment Environment
@inject IdentityRedirectManager RedirectManager
@inject ILogger<Profile> Logger
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Perfil"] — @Brand.Name</PageTitle>

<h1>@L["Perfil"]</h1>
<p class="text-muted">@L["Tu nombre, tu avatar y el acceso a tu cuenta."]</p>

<StatusMessage />

<div class="card mb-4 mt-3">
    <div class="card-body">
        <h5 class="card-title">@L["Nombre"]</h5>
        <p class="small text-muted">@L["Es el nombre que se muestra en la barra lateral y en los emails que te enviamos."]</p>
        <EditForm Model="Input" method="post" OnValidSubmit="SaveProfileAsync" FormName="profile">
            <DataAnnotationsValidator />
            <div class="row g-2 align-items-end">
                <div class="col-sm-6">
                    <label for="Input.DisplayName" class="form-label">@L["Nombre"]</label>
                    <InputText @bind-Value="Input.DisplayName" id="Input.DisplayName" class="form-control" autocomplete="name" placeholder="@L["Tu nombre"]" />
                    <ValidationMessage For="() => Input.DisplayName" class="text-danger" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">@L["Guardar"]</button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">@L["Avatar"]</h5>
        <p class="small text-muted">@L["Sube una foto (PNG, JPG o WebP, máx. 2 MB) o elige uno de los avatares del sistema."]</p>

        <EditForm Model="Avatar" method="post" OnValidSubmit="SaveAvatarAsync" FormName="avatar" enctype="multipart/form-data">
            <div class="d-flex flex-wrap gap-2 mb-3">
                @foreach (var option in DefaultAvatars)
                {
                    var id = $"avatar-{Path.GetFileNameWithoutExtension(option)}";
                    <div>
                        <input type="radio" class="btn-check" name="Avatar.SelectedAvatar" value="@option" id="@id"
                               checked="@(option == _user?.AvatarUrl)" />
                        <label class="btn btn-outline-secondary p-1 rounded-circle" for="@id" title="@L["Elegir este avatar"]">
                            <img src="@option" alt="" width="48" height="48" style="border-radius:50%" />
                        </label>
                    </div>
                }
            </div>

            <div class="row g-2 align-items-end">
                <div class="col-sm-6">
                    <label for="Avatar.UploadedPhoto" class="form-label">@L["O sube tu propia foto"]</label>
                    <input type="file" name="Avatar.UploadedPhoto" id="Avatar.UploadedPhoto" class="form-control" accept="image/png,image/jpeg,image/webp" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">@L["Guardar avatar"]</button>
                </div>
            </div>
        </EditForm>

        @if (!string.IsNullOrEmpty(_user?.AvatarUrl))
        {
            <div class="d-flex align-items-center gap-3 mt-3">
                <img src="@_user.AvatarUrl" alt="@L["Avatar actual"]" width="48" height="48" style="border-radius:50%" />
                <form method="post" @formname="remove-avatar" @onsubmit="RemoveAvatarAsync">
                    <AntiforgeryToken />
                    <button type="submit" class="btn btn-outline-secondary btn-sm">@L["Quitar avatar"]</button>
                </form>
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@L["Contraseña"]</h5>
        @if (devResetLink is not null)
        {
            @* Sin SMTP configurado (solo desarrollo) el enlace se enseña aquí para poder completar el flujo. *@
            <div class="alert alert-warning">
                @L["El envío de emails no está configurado (Email:SmtpHost / Email:From), así que el enlace de restablecimiento se muestra aquí. En producción, configura SMTP — ver README."]
            </div>
            <p><a class="btn btn-primary" href="@devResetLink">@L["Restablecer mi contraseña"]</a></p>
        }
        else
        {
            <p class="small text-muted">@L["Por seguridad, la contraseña se cambia mediante un enlace que te enviamos a tu email."]</p>
            <form method="post" @formname="send-password-reset" @onsubmit="SendPasswordResetAsync">
                <AntiforgeryToken />
                <button type="submit" class="btn btn-outline-primary">@L["Enviarme el enlace de restablecimiento"]</button>
            </form>
        }
    </div>
</div>

@code {
    private static readonly string[] DefaultAvatars =
        Enumerable.Range(1, 8).Select(i => $"/img/avatars/avatar-{i}.svg").ToArray();

    private static readonly Dictionary<string, string> AllowedUploadTypes = new()
    {
        ["image/png"] = ".png",
        ["image/jpeg"] = ".jpg",
        ["image/webp"] = ".webp",
    };

    private const long MaxUploadBytes = 2 * 1024 * 1024;

    private ApplicationUser? _user;
    private string? devResetLink;

    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm(FormName = "profile")]
    private ProfileInputModel Input { get; set; } = new();

    [SupplyParameterFromForm(FormName = "avatar")]
    private AvatarInputModel Avatar { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        _user = await UserManager.GetUserAsync(HttpContext.User);
        if (_user is null)
        {
            RedirectManager.RedirectTo("Account/Login");
            return;
        }

        Input.DisplayName ??= _user.DisplayName;
    }

    private async Task SaveProfileAsync()
    {
        var displayName = Input.DisplayName?.Trim();
        _user!.DisplayName = string.IsNullOrEmpty(displayName) ? null : displayName;
        await UserManager.UpdateAsync(_user);

        // Regenera la cookie para que el claim DisplayName de la sidebar se actualice al momento.
        await SignInManager.RefreshSignInAsync(_user);
        RedirectManager.RedirectToCurrentPageWithStatus(L["Nombre guardado."], HttpContext);
    }

    private async Task SaveAvatarAsync()
    {
        string? avatarUrl;
        // El fichero se lee directamente del form multipart: el binding de formularios SSR no mapea IFormFile.
        var photo = HttpContext.Request.Form.Files.GetFile("Avatar.UploadedPhoto");
        if (photo is { Length: > 0 })
        {
            if (photo.Length > MaxUploadBytes)
            {
                RedirectManager.RedirectToCurrentPageWithStatus(L["Error: la foto no puede superar los 2 MB."], HttpContext);
                return;
            }

            if (!AllowedUploadTypes.TryGetValue(photo.ContentType, out var extension))
            {
                RedirectManager.RedirectToCurrentPageWithStatus(L["Error: formato no admitido. Usa PNG, JPG o WebP."], HttpContext);
                return;
            }

            // Nombre derivado solo del id del usuario + timestamp: nunca del nombre del fichero subido. [SEC]
            var directory = Path.Combine(Environment.WebRootPath, "uploads", "avatars");
            Directory.CreateDirectory(directory);
            DeleteUploadedAvatars(directory);

            var fileName = $"{_user!.Id}-{DateTimeOffset.UtcNow.ToUnixTimeSeconds()}{extension}";
            await using (var stream = File.Create(Path.Combine(directory, fileName)))
            {
                await photo.CopyToAsync(stream);
            }

            avatarUrl = $"/uploads/avatars/{fileName}";
        }
        else if (Avatar.SelectedAvatar is { } selected && DefaultAvatars.Contains(selected))
        {
            avatarUrl = selected;
        }
        else
        {
            RedirectManager.RedirectToCurrentPageWithStatus(L["Error: elige un avatar o sube una foto."], HttpContext);
            return;
        }

        _user!.AvatarUrl = avatarUrl;
        await UserManager.UpdateAsync(_user);
        await SignInManager.RefreshSignInAsync(_user);
        RedirectManager.RedirectToCurrentPageWithStatus(L["Avatar guardado."], HttpContext);
    }

    private async Task RemoveAvatarAsync()
    {
        DeleteUploadedAvatars(Path.Combine(Environment.WebRootPath, "uploads", "avatars"));
        _user!.AvatarUrl = null;
        await UserManager.UpdateAsync(_user);
        await SignInManager.RefreshSignInAsync(_user);
        RedirectManager.RedirectToCurrentPageWithStatus(L["Avatar eliminado."], HttpContext);
    }

    /// <summary>Borra las fotos subidas anteriormente por este usuario (los avatares del sistema no se tocan).</summary>
    private void DeleteUploadedAvatars(string directory)
    {
        if (!Directory.Exists(directory))
        {
            return;
        }

        foreach (var file in Directory.EnumerateFiles(directory, $"{_user!.Id}-*"))
        {
            try
            {
                File.Delete(file);
            }
            catch (IOException ex)
            {
                Logger.LogWarning(ex, "No se pudo borrar el avatar anterior {File}.", file);
            }
        }
    }

    private async Task SendPasswordResetAsync()
    {
        var email = await UserManager.GetEmailAsync(_user!);
        if (email is null)
        {
            return;
        }

        var code = await UserManager.GeneratePasswordResetTokenAsync(_user!);
        code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
        var callbackUrl = NavigationManager.GetUriWithQueryParameters(
            NavigationManager.ToAbsoluteUri("Account/ResetPassword").AbsoluteUri,
            new Dictionary<string, object?> { ["code"] = code });

        if (EmailOptions.IsConfigured)
        {
            await EmailSender.SendPasswordResetLinkAsync(_user!, email, HtmlEncoder.Default.Encode(callbackUrl));
            RedirectManager.RedirectToCurrentPageWithStatus(L["Te hemos enviado un email con el enlace para restablecer tu contraseña."], HttpContext);
        }
        else
        {
            devResetLink = callbackUrl;
        }
    }

    private sealed class ProfileInputModel
    {
        [StringLength(200)]
        [Display(Name = "Nombre")]
        public string? DisplayName { get; set; }
    }

    private sealed class AvatarInputModel
    {
        public string? SelectedAvatar { get; set; }
    }
}
