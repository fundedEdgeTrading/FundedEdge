@page "/psychology"
@rendermode InteractiveServer
@using Markdig
@using FundedEdge.Domain.Psychology
@using FundedEdge.Web.Support
@inject IPsychologyService PsychologyService
@inject ITradingAnalystService AnalystService
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Psicología"] — @Brand.Name</PageTitle>

<h1>@L["Psicología"]</h1>
<p class="text-muted">
    @L["Cruce de tu diario emocional con tu operativa real: qué emociones te cuestan dinero, si hay una mala racha activa y qué trabajar primero."]
</p>

@if (_metrics is null || _analytics is null)
{
    <p><em>@L["Cargando…"]</em></p>
}
else
{
    <div class="kpi-grid">
        <KpiCard Title="@L["Índice de tilt"]" Value="@Out100(_metrics.TiltIndex)" Emphasis="@TiltEmphasis" />
        <KpiCard Title="@L["Score de disciplina"]" Value="@Out100(_metrics.DisciplineScore)" Emphasis="@DisciplineEmphasis" />
        <KpiCard Title="@L["Coste emocional"]" Value="@FormatEmotionalCost(_metrics.EmotionalCostPerR)" />
        <KpiCard Title="@L["Racha de registro"]" Value="@L["{0} día(s)", _metrics.JournalStreakDays]" />
        <KpiCard Title="@L["Cobertura del diario"]" Value="@(_metrics.CoveragePct.ToString("P0"))" />
    </div>

    @if (_badStreak is not null)
    {
        <div class="alert alert-danger mt-3">
            <strong>@_badStreak.Title</strong>
            <p class="mb-0">@_badStreak.Recommendation</p>
        </div>
    }

    <h2 class="mt-4">@L["Emoción → rendimiento"]</h2>
    <p class="chart-caption">@L["Expectancy media (R) por emoción de entrada — la evidencia de qué emociones tratar primero."]</p>
    <EmotionPerformanceChart Points="_analytics.EmotionPerformance" />

    <div class="row mt-4">
        <div class="col-md-6">
            <h2>@L["Calendario emocional"]</h2>
            <p class="chart-caption">@L["Valencia media del día (color) frente al resultado de operativa."]</p>
            <MoodCalendarHeatmap Days="_analytics.MoodCalendar" />
        </div>
        <div class="col-md-6">
            <h2>@L["Capital emocional"]</h2>
            <p class="chart-caption">@L["Media móvil (7 días) de tu valencia emocional diaria — tu \"equity curve\" emocional."]</p>
            <EmotionalCapitalChart Points="_analytics.EmotionalCapitalTrend" />
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <h2>@L["Perfil emocional"]</h2>
            <p class="chart-caption">@L["Distribución de emociones registradas en el período."]</p>
            <EmotionProfileChart Points="_analytics.EmotionFrequency" />
        </div>
        <div class="col-md-6">
            <h2>@L["Tendencia de disciplina"]</h2>
            <p class="chart-caption">@L["% de trades con plan seguido, por semana."]</p>
            <DisciplineTrendChart Points="_analytics.DisciplineTrend" />
        </div>
    </div>

    <h2 class="mt-4">@L["Insights activos"]</h2>
    @if (_metrics.Insights.Count == 0)
    {
        <EmptyState Title="@L["Sin patrones detectados"]" Text="@L["Con más diario emocional registrado, los detectores podrán identificar patrones de riesgo."]" />
    }
    else
    {
        @foreach (var insight in _metrics.Insights.OrderByDescending(i => i.Severity))
        {
            <div class="card mb-2 @SeverityClass(insight.Severity)">
                <div class="card-body">
                    <h5 class="card-title">@insight.Title</h5>
                    <p class="mb-1">@insight.Recommendation</p>
                    <p class="small text-muted mb-0">@L["{0} trade(s) de evidencia", insight.EvidenceTradeIds.Count]</p>
                </div>
            </div>
        }
    }

    @if (_topCostlyEmotions.Count > 0)
    {
        <h2 class="mt-4">@L["Qué trabajar ahora"]</h2>
        @foreach (var emotion in _topCostlyEmotions)
        {
            <div class="card mb-2">
                <div class="card-body">
                    <h5 class="card-title">@EmotionDisplay.Emoji(emotion) @EmotionDisplay.Label(emotion)</h5>
                    <p class="mb-0">@EmotionCoachingTips.TipFor(emotion)</p>
                </div>
            </div>
        }
    }

    <div class="mt-4">
        <button class="btn btn-primary" disabled="@(!AnalystService.IsConfigured || _analyzing)" @onclick="AnalyzeWithAiAsync">
            @(_analyzing ? L["Analizando…"] : L["Analizar mi psicología con IA"])
        </button>
        <a class="btn btn-outline-secondary ms-2" href="emotion-survey">@L["Registrar diario emocional"]</a>
    </div>

    @if (_aiError is not null)
    {
        <div class="alert alert-danger mt-3">@_aiError</div>
    }

    @if (_aiReport is not null)
    {
        <div class="card mt-3">
            <div class="card-body">
                @((MarkupString)RenderMarkdown(_aiReport.Content))
            </div>
        </div>
    }

    <p class="small text-muted mt-4">
        @L["Esta funcionalidad es coaching de rendimiento sobre datos auto-reportados por ti — no es diagnóstico ni tratamiento psicológico. Si sientes malestar sostenido, busca apoyo profesional."]
    </p>
}

@code {
    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml()
        .Build();

    private EmotionAnalyticsDto? _analytics;
    private PsychMetricsDto? _metrics;
    private List<FundedEdge.Domain.Enums.EmotionType> _topCostlyEmotions = [];
    private bool _analyzing;
    private string? _aiError;
    private AiReportDto? _aiReport;
    private PsychInsight? _badStreak;

    private string TiltEmphasis => _metrics?.TiltIndex switch
    {
        >= 60 => "text-danger",
        >= 35 => "text-warning",
        _ => "text-success",
    } ?? "";

    private string DisciplineEmphasis => _metrics?.DisciplineScore switch
    {
        >= 70 => "text-success",
        >= 40 => "text-warning",
        _ => "text-danger",
    } ?? "";

    protected override async Task OnInitializedAsync()
    {
        var to = DateOnly.FromDateTime(DateTime.UtcNow.Date);
        var from = to.AddDays(-90);

        _analytics = await PsychologyService.GetAnalyticsAsync(from, to);
        _metrics = await PsychologyService.GetMetricsAsync(from, to);
        _badStreak = _metrics.Insights.FirstOrDefault(i => i.DetectorKey == "mala-racha-emocional");

        _topCostlyEmotions = _analytics.EmotionPerformance
            .Where(p => p.AvgRMultiple is < 0)
            .OrderBy(p => p.AvgRMultiple)
            .Take(2)
            .Select(p => p.Emotion)
            .ToList();
    }

    private async Task AnalyzeWithAiAsync()
    {
        _analyzing = true;
        _aiError = null;
        try
        {
            _aiReport = await AnalystService.GeneratePsychologyReportAsync();
        }
        catch (Exception ex)
        {
            _aiError = ex.Message;
        }
        finally
        {
            _analyzing = false;
        }
    }

    private static string SeverityClass(InsightSeverity severity) => severity switch
    {
        InsightSeverity.Critical => "psych-severity-critical",
        InsightSeverity.Warning => "psych-severity-warning",
        _ => "psych-severity-info",
    };

    private static string RenderMarkdown(string markdown) => Markdown.ToHtml(markdown, MarkdownPipeline);

    private static string Out100(int value) => $"{value}/100";
    private static string FormatEmotionalCost(decimal? value) => value is null ? "—" : $"{value:0.00}R";
}
