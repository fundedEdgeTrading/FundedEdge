@page "/firms"
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer
@implements IDisposable
@inject IPropFirmService PropFirmService
@inject IEvaluationProgramService ProgramService
@inject IKpiService KpiService
@inject CurrencyState Currency
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Firmas"] — @Brand.Name</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@L["Firmas de fondeo"]</h1>
    <AuthorizeView Roles="Administrator">
        <a class="btn btn-outline-primary" href="admin/prop-firms">@L["Gestionar reglas"]</a>
    </AuthorizeView>
</div>

@if (_firms is null)
{
    <p><em>@L["Cargando…"]</em></p>
}
else if (_firms.Count == 0)
{
    <p class="text-muted">@L["Todavía no hay firmas registradas."]</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>@L["Nombre"]</th>
                    <th>@L["Estado"]</th>
                    <th>@L["País"]</th>
                    <th>Web</th>
                    <th>@L["Días mín. entre payouts"]</th>
                    <th title="@L["Días entre solicitar y cobrar un payout, agregado anónimo de la comunidad (mediana / P90)"]">@L["Tiempo de pago"]</th>
                    <th>@L["Cuentas"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var firm in _firms)
                {
                    <tr>
                        <td>@firm.Name</td>
                        <td>
                            <span class="badge @HealthBadge(firm.HealthStatus)">@HealthLabel(firm.HealthStatus)</span>
                            @if (!string.IsNullOrWhiteSpace(firm.HealthNotes))
                            {
                                <span class="ms-1 text-muted small" title="@firm.HealthNotes">ⓘ</span>
                            }
                        </td>
                        <td>@(firm.Country ?? "—")</td>
                        <td>@firm.Website</td>
                        <td>@(firm.MinDaysBetweenPayouts?.ToString() ?? "—")</td>
                        <td>
                            @if (_payoutSpeed is not null && _payoutSpeed.TryGetValue(firm.Id, out var speed))
                            {
                                <span title="@string.Format(L["{0} payouts de {1} traders"], speed.PayoutCount, speed.TraderCount)">
                                    @string.Format(L["{0} / {1} días"], speed.MedianDays, speed.P90Days)
                                </span>
                            }
                            else
                            {
                                <span class="text-muted" title="@L["Sin muestra suficiente en la comunidad todavía"]">—</span>
                            }
                        </td>
                        <td>@firm.AccountCount</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* ── P&L de negocio por firma (GUIA_FUNCIONALIDADES_PROPUESTAS.md §3.1) ─────────────────────── *@

@if (_firmBreakdown is { Count: > 0 })
{
    <hr class="my-4" />
    <h2 class="h4">@L["P&L de negocio por firma"]</h2>
    <p class="text-muted small">@L["La cuenta de resultados de cada firma con la que operas: ROI, coste por cuenta fondeada y tiempo medio hasta el primer payout."]</p>
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
            <thead>
                <tr>
                    <th>@L["Firma"]</th>
                    <th class="text-end">@L["Compradas"]</th>
                    <th class="text-end">@L["Fondeadas"]</th>
                    <th class="text-end">@L["Tasa de aprobación"]</th>
                    <th class="text-end">@L["Coste total"]</th>
                    <th class="text-end">@L["Payouts totales"]</th>
                    <th class="text-end">@L["Cashflow neto"]</th>
                    <th class="text-end">@L["Coste / fondeada"]</th>
                    <th class="text-end">ROI</th>
                    <th class="text-end">@L["Días a 1er payout"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in _firmBreakdown)
                {
                    <tr>
                        <td>@f.FirmName</td>
                        <td class="text-end">@f.AccountsPurchased</td>
                        <td class="text-end">@f.AccountsFunded</td>
                        <td class="text-end">@(f.PassRate is null ? "—" : f.PassRate.Value.ToString("P0"))</td>
                        <td class="text-end">@Currency.Format(f.TotalCosts, 0)</td>
                        <td class="text-end">@Currency.Format(f.TotalPayoutsReceived, 0)</td>
                        <td class="text-end @(f.NetCashflow >= 0 ? "text-success" : "text-danger")">@Currency.Format(f.NetCashflow, 0)</td>
                        <td class="text-end">@(f.CostPerFundedAccount is null ? "—" : Currency.Format(f.CostPerFundedAccount, 0))</td>
                        <td class="text-end @(f.BusinessRoi is >= 0 ? "text-success" : f.BusinessRoi is < 0 ? "text-danger" : "")">@(f.BusinessRoi is null ? "—" : f.BusinessRoi.Value.ToString("P0"))</td>
                        <td class="text-end">@(f.AvgDaysFundedToFirstPayout is null ? "—" : $"{f.AvgDaysFundedToFirstPayout:0}")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* ── Sección de programas de evaluación ─────────────────────────────────────────────────── *@

<hr class="my-4" />
<h2 class="h4">@L["Programas de evaluación"]</h2>

<div class="mb-3">
    <label class="form-label fw-semibold">@L["Firma"]</label>
    <select class="form-select w-auto d-inline-block ms-2" @bind="_selectedFirmId" @bind:after="LoadProgramsAsync">
        <option value="">@L["Selecciona una firma"]</option>
        @if (_firms is not null)
        {
            @foreach (var f in _firms)
            {
                <option value="@f.Id">@f.Name</option>
            }
        }
    </select>
</div>

@if (_selectedFirmId is not null)
{
    @if (_programs is null)
    {
        <p><em>@L["Cargando…"]</em></p>
    }
    else if (_programs.Count == 0)
    {
        <p class="text-muted">@L["Esta firma no tiene programas activos."]</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle">
                <thead>
                    <tr>
                        <th>@L["Nombre"]</th>
                        <th class="text-end">@L["Tamaño"]</th>
                        <th class="text-end">@L["Objetivo de beneficio"]</th>
                        <th class="text-end">@L["Drawdown máx."]</th>
                        <th>DD</th>
                        <th class="text-end">@L["Reparto"]</th>
                        <th class="text-end">@L["Días payouts"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _programs)
                    {
                        <tr>
                            <td>@p.Name</td>
                            <td class="text-end">@Currency.Format(p.AccountSize, 0)</td>
                            <td class="text-end">@Currency.Format(p.ProfitTarget)</td>
                            <td class="text-end">@Currency.Format(p.MaxDrawdown)</td>
                            <td>@p.DrawdownType</td>
                            <td class="text-end">@p.PayoutSplitTraderPct.ToString("P0")</td>
                            <td class="text-end">@(p.PayoutMinDaysBetween?.ToString() ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private List<PropFirmDto>? _firms;
    private List<FirmBusinessBreakdownDto>? _firmBreakdown;
    private IReadOnlyDictionary<Guid, FirmPayoutSpeedDto>? _payoutSpeed;

    private Guid? _selectedFirmId;
    private List<EvaluationProgramDto>? _programs;

    protected override async Task OnInitializedAsync()
    {
        Currency.Changed += OnCurrencyChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _firms = (await PropFirmService.GetAllAsync()).ToList();
        _firmBreakdown = (await KpiService.GetFirmBusinessBreakdownAsync()).ToList();
        _payoutSpeed = await PropFirmService.GetPayoutSpeedAsync();
    }

    private static string HealthBadge(FirmHealthStatus status) => status switch
    {
        FirmHealthStatus.Watch => "text-bg-warning",
        FirmHealthStatus.Closed => "text-bg-danger",
        _ => "text-bg-success",
    };

    private string HealthLabel(FirmHealthStatus status) => status switch
    {
        FirmHealthStatus.Watch => L["En observación"],
        FirmHealthStatus.Closed => L["Cerrada"],
        _ => L["Activa"],
    };

    private void OnCurrencyChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Currency.Changed -= OnCurrencyChanged;

    private async Task LoadProgramsAsync()
    {
        _programs = null;
        if (_selectedFirmId is null) return;
        _programs = (await ProgramService.GetByFirmAsync(_selectedFirmId.Value)).ToList();
    }
}
